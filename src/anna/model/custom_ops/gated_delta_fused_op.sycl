void validate_gated_delta_inputs(
    const at::Tensor& query_in,
    const at::Tensor& key_in,
    const at::Tensor& value_in,
    const at::Tensor& g_in,
    const at::Tensor& beta_in,
    const at::Tensor& state_in) {
  TORCH_CHECK(query_in.dim() == 4, "query must be [batch, seq, heads, head_dim]");
  TORCH_CHECK(key_in.dim() == 4, "key must be [batch, seq, heads, head_dim]");
  TORCH_CHECK(value_in.dim() == 4, "value must be [batch, seq, heads, head_dim]");
  TORCH_CHECK(g_in.dim() == 3, "g must be [batch, seq, heads]");
  TORCH_CHECK(beta_in.dim() == 3, "beta must be [batch, seq, heads]");
  TORCH_CHECK(state_in.dim() == 4, "state must be [batch, heads, key_head_dim, value_head_dim]");

  TORCH_CHECK(query_in.size(0) == key_in.size(0), "query/key batch size mismatch");
  TORCH_CHECK(query_in.size(0) == value_in.size(0), "query/value batch size mismatch");
  TORCH_CHECK(query_in.size(1) == key_in.size(1), "query/key sequence length mismatch");
  TORCH_CHECK(query_in.size(1) == value_in.size(1), "query/value sequence length mismatch");
  TORCH_CHECK(query_in.size(2) == key_in.size(2), "query/key head count mismatch");
  TORCH_CHECK(query_in.size(2) == value_in.size(2), "query/value head count mismatch");
  TORCH_CHECK(query_in.size(3) == key_in.size(3), "query/key head dim mismatch");
  TORCH_CHECK(query_in.size(2) > 0, "gated_delta head count must be positive");
  TORCH_CHECK(query_in.size(3) > 0, "gated_delta key head dim must be positive");
  TORCH_CHECK(value_in.size(3) > 0, "gated_delta value head dim must be positive");
  TORCH_CHECK(query_in.size(2) == state_in.size(1), "query/state head count mismatch");
  TORCH_CHECK(query_in.size(3) == state_in.size(2), "query/state key head dim mismatch");
  TORCH_CHECK(value_in.size(3) == state_in.size(3), "value/state value head dim mismatch");

  TORCH_CHECK(g_in.size(0) == query_in.size(0), "g batch size mismatch");
  TORCH_CHECK(g_in.size(1) == query_in.size(1), "g sequence length mismatch");
  TORCH_CHECK(g_in.size(2) == query_in.size(2), "g head count mismatch");
  TORCH_CHECK(beta_in.sizes() == g_in.sizes(), "beta shape must match g");

  TORCH_CHECK(
      query_in.scalar_type() == key_in.scalar_type() &&
          query_in.scalar_type() == value_in.scalar_type(),
      "query, key, and value must share the same dtype");
  TORCH_CHECK(
      query_in.scalar_type() == at::kHalf || query_in.scalar_type() == at::kBFloat16 ||
          query_in.scalar_type() == at::kFloat,
      "gated_delta XPU kernel supports float16, bfloat16, and float32 query/key/value inputs");
  TORCH_CHECK(g_in.scalar_type() == at::kFloat, "g must be float32");
  TORCH_CHECK(beta_in.scalar_type() == at::kFloat, "beta must be float32");
  TORCH_CHECK(state_in.scalar_type() == at::kFloat, "state must be float32");
}

void validate_gated_delta_xpu_inputs(
    const at::Tensor& query_in,
    const at::Tensor& key_in,
    const at::Tensor& value_in,
    const at::Tensor& g_in,
    const at::Tensor& beta_in,
    const at::Tensor& state_in) {
  auto device = query_in.device();
  TORCH_CHECK(device.type() == c10::DeviceType::XPU, "query must be an XPU tensor");
  TORCH_CHECK(key_in.device() == device, "key must be on the same device as query");
  TORCH_CHECK(value_in.device() == device, "value must be on the same device as query");
  TORCH_CHECK(g_in.device() == device, "g must be on the same device as query");
  TORCH_CHECK(beta_in.device() == device, "beta must be on the same device as query");
  TORCH_CHECK(state_in.device() == device, "state must be on the same device as query");
  TORCH_CHECK(query_in.is_contiguous(), "query must be contiguous");
  TORCH_CHECK(key_in.is_contiguous(), "key must be contiguous");
  TORCH_CHECK(value_in.is_contiguous(), "value must be contiguous");
  TORCH_CHECK(g_in.is_contiguous(), "g must be contiguous");
  TORCH_CHECK(beta_in.is_contiguous(), "beta must be contiguous");
  TORCH_CHECK(state_in.is_contiguous(), "state must be contiguous");
}

int64_t next_power_of_two(int64_t value) {
  int64_t result = 1;
  while (result < value) {
    result <<= 1;
  }
  return result;
}

bool is_power_of_two(int64_t value) {
  return value > 0 && (value & (value - 1)) == 0;
}

int64_t gated_delta_local_memory_bytes_required(int64_t key_head_dim, int64_t local_size) {
  return static_cast<int64_t>(sizeof(float)) * ((2 * local_size) + (2 * key_head_dim));
}

void validate_gated_delta_local_memory_requirements(
    const sycl::device& device,
    int64_t key_head_dim,
    int64_t local_size) {
  TORCH_CHECK(key_head_dim > 0, "gated_delta key head dim must be positive");
  TORCH_CHECK(local_size > 0, "gated_delta local reduction size must be positive");
  TORCH_CHECK(is_power_of_two(local_size), "gated_delta local reduction size must be a power of two");
  const auto local_mem_size = static_cast<int64_t>(device.get_info<sycl::info::device::local_mem_size>());
  const auto required_bytes = gated_delta_local_memory_bytes_required(key_head_dim, local_size);
  TORCH_CHECK(
      required_bytes <= local_mem_size,
      "gated_delta local memory requirement exceeds device limit: required=",
      required_bytes,
      " bytes, available=",
      local_mem_size,
      " bytes");
}

template <typename scalar_t>
inline float load_as_float(const scalar_t* ptr, int64_t idx) {
  return static_cast<float>(ptr[idx]);
}

inline float load_grouped_int4_weight(
    const int32_t* qweight_ptr,
    const float* qscale_ptr,
    const int8_t* qzeros_ptr,
    int64_t bank_slot,
    int64_t out_idx,
    int64_t in_idx,
    int64_t out_features,
    int64_t packed_cols,
    int64_t group_count,
    int64_t group_size) {
  const int64_t packed_idx = in_idx >> 3;
  const int64_t shift = (in_idx & 7) << 2;
  const int64_t qweight_offset = (bank_slot * out_features + out_idx) * packed_cols + packed_idx;
  const uint32_t packed = static_cast<uint32_t>(qweight_ptr[qweight_offset]);
  const int32_t qvalue = static_cast<int32_t>((packed >> shift) & 0xFu);
  int64_t group_idx = in_idx / group_size;
  group_idx = sycl::min<int64_t>(group_idx, group_count - 1);
  const int64_t scale_offset = (bank_slot * group_count + group_idx) * out_features + out_idx;
  const int32_t zero_point = static_cast<int32_t>(qzeros_ptr[scale_offset]);
  return (static_cast<float>(qvalue - zero_point)) * qscale_ptr[scale_offset];
}

template <typename scalar_t, typename PartialAccessor, typename VectorAccessor>
inline void normalize_gated_delta_qk(
    const scalar_t* query_ptr,
    const scalar_t* key_ptr,
    int64_t query_base,
    int64_t key_base,
    int64_t key_head_dim,
    int64_t local_size,
    float l2_eps_f,
    float query_scale_base,
    sycl::nd_item<2> item,
    PartialAccessor& partial_sum,
    PartialAccessor& partial_sum_aux,
    VectorAccessor& normalized_query,
    VectorAccessor& normalized_key) {
  const int64_t lane = static_cast<int64_t>(item.get_local_id(1));
  auto sg = item.get_sub_group();
  const int64_t subgroup_lane = static_cast<int64_t>(sg.get_local_linear_id());
  const int64_t subgroup_idx = static_cast<int64_t>(sg.get_group_linear_id());
  const int64_t subgroup_size = static_cast<int64_t>(sg.get_local_linear_range());
  const int64_t raw_subgroup_count = (local_size + subgroup_size - 1) / subgroup_size;
  const int64_t subgroup_count = raw_subgroup_count < local_size ? raw_subgroup_count : local_size;

  float local_query_sum_sq = 0.0f;
  float local_key_sum_sq = 0.0f;
  for (int64_t k_idx = lane; k_idx < key_head_dim; k_idx += local_size) {
    const float raw_query = load_as_float(query_ptr, query_base + k_idx);
    const float raw_key = load_as_float(key_ptr, key_base + k_idx);
    normalized_query[k_idx] = raw_query;
    normalized_key[k_idx] = raw_key;
    local_query_sum_sq += raw_query * raw_query;
    local_key_sum_sq += raw_key * raw_key;
  }

  const float subgroup_query_sum_sq = sycl::reduce_over_group(sg, local_query_sum_sq, sycl::plus<float>());
  const float subgroup_key_sum_sq = sycl::reduce_over_group(sg, local_key_sum_sq, sycl::plus<float>());
  if (subgroup_lane == 0 && subgroup_idx < local_size) {
    partial_sum[subgroup_idx] = subgroup_query_sum_sq;
    partial_sum_aux[subgroup_idx] = subgroup_key_sum_sq;
  }
  item.barrier(sycl::access::fence_space::local_space);

  partial_sum[lane] = lane < subgroup_count ? partial_sum[lane] : 0.0f;
  partial_sum_aux[lane] = lane < subgroup_count ? partial_sum_aux[lane] : 0.0f;
  item.barrier(sycl::access::fence_space::local_space);

  for (int64_t stride = local_size / 2; stride > 0; stride >>= 1) {
    if (lane < stride) {
      partial_sum[lane] += partial_sum[lane + stride];
      partial_sum_aux[lane] += partial_sum_aux[lane + stride];
    }
    item.barrier(sycl::access::fence_space::local_space);
  }

  const float query_scale = sycl::rsqrt(partial_sum[0] + l2_eps_f) * query_scale_base;
  const float key_scale = sycl::rsqrt(partial_sum_aux[0] + l2_eps_f);
  for (int64_t k_idx = lane; k_idx < key_head_dim; k_idx += local_size) {
    normalized_query[k_idx] *= query_scale;
    normalized_key[k_idx] *= key_scale;
  }
  item.barrier(sycl::access::fence_space::local_space);
}

template <typename VectorAccessor>
inline float gated_delta_decay_state_and_compute_kv_mem(
    const float* state_source_ptr,
    float* state_write_ptr,
    int64_t state_base,
    int64_t value_head_dim,
    int64_t key_head_dim,
    int64_t value_idx,
    float g_scale,
    VectorAccessor& normalized_key) {
  float kv_mem = 0.0f;
  for (int64_t k_idx = 0; k_idx < key_head_dim; ++k_idx) {
    const int64_t state_index = state_base + k_idx * value_head_dim + value_idx;
    const float decayed = state_source_ptr[state_index] * g_scale;
    state_write_ptr[state_index] = decayed;
    kv_mem += decayed * normalized_key[k_idx];
  }
  return kv_mem;
}

template <typename scalar_t>
inline float gated_delta_compute_delta(
    const scalar_t* value_ptr,
    int64_t value_base,
    int64_t value_idx,
    float kv_mem,
    float beta_value) {
  const float value_item = load_as_float(value_ptr, value_base + value_idx);
  return (value_item - kv_mem) * beta_value;
}

template <typename VectorAccessor>
inline void gated_delta_apply_delta_update(
    float* state_write_ptr,
    int64_t state_base,
    int64_t value_head_dim,
    int64_t key_head_dim,
    int64_t value_idx,
    float delta,
    VectorAccessor& normalized_key) {
  for (int64_t k_idx = 0; k_idx < key_head_dim; ++k_idx) {
    const int64_t state_index = state_base + k_idx * value_head_dim + value_idx;
    const float updated = state_write_ptr[state_index] + normalized_key[k_idx] * delta;
    state_write_ptr[state_index] = updated;
  }
}

template <typename VectorAccessor>
inline float gated_delta_accumulate_output(
    const float* state_write_ptr,
    int64_t state_base,
    int64_t value_head_dim,
    int64_t key_head_dim,
    int64_t value_idx,
    VectorAccessor& normalized_query) {
  float out_value = 0.0f;
  for (int64_t k_idx = 0; k_idx < key_head_dim; ++k_idx) {
    const int64_t state_index = state_base + k_idx * value_head_dim + value_idx;
    out_value += state_write_ptr[state_index] * normalized_query[k_idx];
  }
  return out_value;
}

template <typename scalar_t>
inline void gated_delta_store_output(
    scalar_t* output_ptr,
    int64_t output_index,
    float out_value) {
  output_ptr[output_index] = static_cast<scalar_t>(out_value);
}

void validate_rmsnorm_inputs(
    const at::Tensor& input,
    const at::Tensor& weight) {
  TORCH_CHECK(input.dim() >= 1, "input must have at least one dimension");
  TORCH_CHECK(weight.dim() == 1, "weight must be [hidden_size]");
  TORCH_CHECK(input.size(-1) == weight.size(0), "weight size must match the last input dimension");
  TORCH_CHECK(at::isFloatingType(input.scalar_type()), "input must be a floating-point tensor");
  TORCH_CHECK(at::isFloatingType(weight.scalar_type()), "weight must be a floating-point tensor");
  TORCH_CHECK(
      input.scalar_type() == at::kHalf || input.scalar_type() == at::kBFloat16 ||
          input.scalar_type() == at::kFloat,
      "rmsnorm_fused XPU kernel supports float16, bfloat16, and float32 inputs");
}

void validate_rmsnorm_xpu_inputs(
    const at::Tensor& input,
    const at::Tensor& weight) {
  auto device = input.device();
  TORCH_CHECK(device.type() == c10::DeviceType::XPU, "input must be an XPU tensor");
  TORCH_CHECK(weight.device() == device, "weight must be on the same device as input");
}

void validate_rmsnorm_gated_inputs(
    const at::Tensor& input,
    const at::Tensor& gate,
    const at::Tensor& weight) {
  validate_rmsnorm_inputs(input, weight);
  TORCH_CHECK(gate.sizes() == input.sizes(), "gate shape must match input shape");
  TORCH_CHECK(gate.scalar_type() == input.scalar_type(), "gate dtype must match input dtype");
}

void validate_rmsnorm_gated_xpu_inputs(
    const at::Tensor& input,
    const at::Tensor& gate,
    const at::Tensor& weight) {
  validate_rmsnorm_xpu_inputs(input, weight);
  TORCH_CHECK(gate.device() == input.device(), "gate must be on the same device as input");
}

void validate_qk_norm_rotary_inputs(
    const at::Tensor& query,
    const at::Tensor& key,
    const at::Tensor& query_norm_weight,
    const at::Tensor& key_norm_weight,
    const at::Tensor& cos,
    const at::Tensor& sin) {
  TORCH_CHECK(query.dim() == 4, "query must be [batch, heads, seq_len, head_dim]");
  TORCH_CHECK(key.dim() == 4, "key must be [batch, heads, seq_len, head_dim]");
  TORCH_CHECK(cos.dim() == 3, "cos must be [batch, seq_len, rotary_dim]");
  TORCH_CHECK(sin.dim() == 3, "sin must be [batch, seq_len, rotary_dim]");
  TORCH_CHECK(query.scalar_type() == key.scalar_type(), "query and key must share the same dtype");
  TORCH_CHECK(
      query.scalar_type() == at::kHalf || query.scalar_type() == at::kBFloat16 ||
          query.scalar_type() == at::kFloat,
      "qk_norm_rotary_fused XPU kernel supports float16, bfloat16, and float32 inputs");
  TORCH_CHECK(query.size(0) == key.size(0), "query/key batch size mismatch");
  TORCH_CHECK(query.size(2) == key.size(2), "query/key sequence length mismatch");
  TORCH_CHECK(query.size(3) == key.size(3), "query/key head_dim mismatch");
  TORCH_CHECK(query_norm_weight.dim() == 1, "query_norm_weight must be [head_dim]");
  TORCH_CHECK(key_norm_weight.dim() == 1, "key_norm_weight must be [head_dim]");
  TORCH_CHECK(query_norm_weight.size(0) == query.size(3), "query_norm_weight size must match query head_dim");
  TORCH_CHECK(key_norm_weight.size(0) == key.size(3), "key_norm_weight size must match key head_dim");
  TORCH_CHECK(at::isFloatingType(query_norm_weight.scalar_type()), "query_norm_weight must be floating-point");
  TORCH_CHECK(at::isFloatingType(key_norm_weight.scalar_type()), "key_norm_weight must be floating-point");
  TORCH_CHECK(cos.sizes() == sin.sizes(), "cos and sin must share the same shape");
  TORCH_CHECK(cos.size(0) == query.size(0), "cos batch size must match query");
  TORCH_CHECK(cos.size(1) == query.size(2), "cos sequence length must match query");
  TORCH_CHECK(cos.size(2) <= query.size(3), "rotary_dim must be <= head_dim");
  TORCH_CHECK(cos.size(2) >= 2, "rotary_dim must be >= 2");
  TORCH_CHECK(cos.size(2) % 2 == 0, "rotary_dim must be even");
  TORCH_CHECK(at::isFloatingType(cos.scalar_type()), "cos must be floating-point");
  TORCH_CHECK(at::isFloatingType(sin.scalar_type()), "sin must be floating-point");
}

void validate_qk_norm_rotary_xpu_inputs(
    const at::Tensor& query,
    const at::Tensor& key,
    const at::Tensor& query_norm_weight,
    const at::Tensor& key_norm_weight,
    const at::Tensor& cos,
    const at::Tensor& sin) {
  auto device = query.device();
  TORCH_CHECK(device.type() == c10::DeviceType::XPU, "query must be an XPU tensor");
  TORCH_CHECK(key.device() == device, "key must be on the same device as query");
  TORCH_CHECK(query_norm_weight.device() == device, "query_norm_weight must be on the same device as query");
  TORCH_CHECK(key_norm_weight.device() == device, "key_norm_weight must be on the same device as query");
  TORCH_CHECK(cos.device() == device, "cos must be on the same device as query");
  TORCH_CHECK(sin.device() == device, "sin must be on the same device as query");
}

void validate_moe_router_inputs(
    const at::Tensor& router_logits,
    int64_t top_k) {
  TORCH_CHECK(router_logits.dim() == 2, "router_logits must be [tokens, num_experts]");
  TORCH_CHECK(router_logits.size(1) >= 1, "num_experts must be positive");
  TORCH_CHECK(top_k >= 1, "top_k must be positive");
  TORCH_CHECK(top_k <= router_logits.size(1), "top_k must be <= num_experts");
  TORCH_CHECK(at::isFloatingType(router_logits.scalar_type()), "router_logits must be a floating-point tensor");
  TORCH_CHECK(
      router_logits.scalar_type() == at::kHalf || router_logits.scalar_type() == at::kBFloat16 ||
          router_logits.scalar_type() == at::kFloat,
      "moe_router_fused XPU kernel supports float16, bfloat16, and float32 inputs");
}

void validate_moe_router_xpu_inputs(const at::Tensor& router_logits) {
  auto device = router_logits.device();
  TORCH_CHECK(device.type() == c10::DeviceType::XPU, "router_logits must be an XPU tensor");
}

void validate_moe_dispatch_inputs(
    const at::Tensor& hidden_states,
    const at::Tensor& routing_weights,
    const at::Tensor& selected_experts,
    const at::Tensor& expert_usage) {
  TORCH_CHECK(hidden_states.dim() == 2, "hidden_states must be [tokens, hidden_dim]");
  TORCH_CHECK(routing_weights.dim() == 2, "routing_weights must be [tokens, top_k]");
  TORCH_CHECK(selected_experts.sizes() == routing_weights.sizes(), "selected_experts shape must match routing_weights");
  TORCH_CHECK(expert_usage.dim() == 1, "expert_usage must be [num_experts]");
  TORCH_CHECK(hidden_states.size(0) == routing_weights.size(0), "hidden_states/routing_weights token count mismatch");
  TORCH_CHECK(hidden_states.size(1) > 0, "hidden_dim must be positive");
  TORCH_CHECK(routing_weights.size(1) > 0, "top_k must be positive");
  TORCH_CHECK(expert_usage.size(0) > 0, "num_experts must be positive");
  TORCH_CHECK(selected_experts.scalar_type() == at::kLong, "selected_experts must be int64");
  TORCH_CHECK(
      expert_usage.scalar_type() == at::kInt || expert_usage.scalar_type() == at::kLong,
      "expert_usage must be int32 or int64");
  TORCH_CHECK(at::isFloatingType(hidden_states.scalar_type()), "hidden_states must be floating-point");
  TORCH_CHECK(hidden_states.scalar_type() == routing_weights.scalar_type(), "routing_weights dtype must match hidden_states");
  TORCH_CHECK(
      hidden_states.scalar_type() == at::kHalf || hidden_states.scalar_type() == at::kBFloat16 ||
          hidden_states.scalar_type() == at::kFloat,
      "moe_dispatch_fused XPU kernel supports float16, bfloat16, and float32 hidden states");
}

void validate_moe_dispatch_xpu_inputs(
    const at::Tensor& hidden_states,
    const at::Tensor& routing_weights,
    const at::Tensor& selected_experts,
    const at::Tensor& expert_usage) {
  auto device = hidden_states.device();
  TORCH_CHECK(device.type() == c10::DeviceType::XPU, "hidden_states must be an XPU tensor");
  TORCH_CHECK(routing_weights.device() == device, "routing_weights must be on the same device as hidden_states");
  TORCH_CHECK(selected_experts.device() == device, "selected_experts must be on the same device as hidden_states");
  TORCH_CHECK(expert_usage.device() == device, "expert_usage must be on the same device as hidden_states");
}

void validate_moe_scatter_inputs(
    const at::Tensor& compact_outputs,
    const at::Tensor& sorted_token_idx,
    int64_t num_tokens) {
  TORCH_CHECK(compact_outputs.dim() == 2, "compact_outputs must be [routes, hidden_dim]");
  TORCH_CHECK(sorted_token_idx.dim() == 1, "sorted_token_idx must be [routes]");
  TORCH_CHECK(sorted_token_idx.size(0) == compact_outputs.size(0), "sorted_token_idx route count mismatch");
  TORCH_CHECK(num_tokens >= 0, "num_tokens must be non-negative");
  TORCH_CHECK(compact_outputs.size(1) > 0, "hidden_dim must be positive");
  TORCH_CHECK(sorted_token_idx.scalar_type() == at::kLong, "sorted_token_idx must be int64");
  TORCH_CHECK(at::isFloatingType(compact_outputs.scalar_type()), "compact_outputs must be floating-point");
  TORCH_CHECK(
      compact_outputs.scalar_type() == at::kHalf || compact_outputs.scalar_type() == at::kBFloat16 ||
          compact_outputs.scalar_type() == at::kFloat,
      "moe_scatter_fused XPU kernel supports float16, bfloat16, and float32 compact outputs");
}

void validate_moe_scatter_xpu_inputs(
    const at::Tensor& compact_outputs,
    const at::Tensor& sorted_token_idx) {
  auto device = compact_outputs.device();
  TORCH_CHECK(device.type() == c10::DeviceType::XPU, "compact_outputs must be an XPU tensor");
  TORCH_CHECK(sorted_token_idx.device() == device, "sorted_token_idx must be on the same device as compact_outputs");
}

void validate_int4_expert_bank_tensor(
    const at::Tensor& tensor,
    const char* name,
    int64_t rank,
    at::ScalarType scalar_type,
    int64_t active_capacity) {
  TORCH_CHECK(tensor.dim() == rank, name, " must have rank ", rank);
  TORCH_CHECK(tensor.scalar_type() == scalar_type, name, " has an unexpected dtype");
  TORCH_CHECK(tensor.size(0) == active_capacity, name, " bank capacity mismatch");
  TORCH_CHECK(tensor.is_contiguous(), name, " must be contiguous");
}

void validate_moe_grouped_int4_mlp_inputs(
    const at::Tensor& compact_hidden_states,
    const at::Tensor& compact_routing_weights,
    const at::Tensor& compact_outputs,
    const at::Tensor& expert_offsets,
    const at::Tensor& active_experts,
    const at::Tensor& active_slots,
    const at::Tensor& gate_qweight,
    const at::Tensor& gate_qscale,
    const at::Tensor& gate_qzeros,
    const at::Tensor& up_qweight,
    const at::Tensor& up_qscale,
    const at::Tensor& up_qzeros,
    const at::Tensor& down_qweight,
    const at::Tensor& down_qscale,
    const at::Tensor& down_qzeros,
    int64_t group_size,
    int64_t max_routes_per_expert) {
  TORCH_CHECK(compact_hidden_states.dim() == 2, "compact_hidden_states must be [routes, hidden_dim]");
  TORCH_CHECK(compact_routing_weights.dim() == 2, "compact_routing_weights must be [routes, 1]");
  TORCH_CHECK(compact_outputs.dim() == 2, "compact_outputs must be [routes, hidden_dim]");
  TORCH_CHECK(compact_routing_weights.size(0) == compact_hidden_states.size(0), "routing route count mismatch");
  TORCH_CHECK(compact_routing_weights.size(1) == 1, "compact_routing_weights must have trailing dimension 1");
  TORCH_CHECK(compact_outputs.sizes() == compact_hidden_states.sizes(), "compact_outputs shape must match compact_hidden_states");
  TORCH_CHECK(compact_outputs.is_contiguous(), "compact_outputs must be contiguous");
  TORCH_CHECK(expert_offsets.dim() == 1, "expert_offsets must be [num_experts + 1]");
  TORCH_CHECK(expert_offsets.size(0) >= 2, "expert_offsets must contain at least two entries");
  TORCH_CHECK(active_experts.dim() == 1, "active_experts must be [active_count]");
  TORCH_CHECK(active_slots.dim() == 1, "active_slots must be [active_count]");
  TORCH_CHECK(active_experts.size(0) == active_slots.size(0), "active_experts/active_slots count mismatch");
  TORCH_CHECK(active_experts.size(0) > 0, "active expert count must be positive");
  TORCH_CHECK(compact_hidden_states.size(1) > 0, "hidden_dim must be positive");
  TORCH_CHECK(group_size > 0 && group_size % 32 == 0, "group_size must be a positive multiple of 32");
  TORCH_CHECK(max_routes_per_expert > 0, "max_routes_per_expert must be positive");
  TORCH_CHECK(expert_offsets.scalar_type() == at::kLong, "expert_offsets must be int64");
  TORCH_CHECK(active_experts.scalar_type() == at::kLong, "active_experts must be int64");
  TORCH_CHECK(active_slots.scalar_type() == at::kLong, "active_slots must be int64");
  TORCH_CHECK(at::isFloatingType(compact_hidden_states.scalar_type()), "compact_hidden_states must be floating-point");
  TORCH_CHECK(
      compact_hidden_states.scalar_type() == at::kHalf || compact_hidden_states.scalar_type() == at::kBFloat16 ||
          compact_hidden_states.scalar_type() == at::kFloat,
      "moe_grouped_int4_mlp_fused XPU kernel supports float16, bfloat16, and float32 hidden states");
  TORCH_CHECK(
      compact_routing_weights.scalar_type() == compact_hidden_states.scalar_type(),
      "compact_routing_weights dtype must match compact_hidden_states");
  TORCH_CHECK(
      compact_outputs.scalar_type() == compact_hidden_states.scalar_type(),
      "compact_outputs dtype must match compact_hidden_states");

  TORCH_CHECK(gate_qweight.dim() == 3, "gate_qweight must have rank 3");
  TORCH_CHECK(gate_qweight.scalar_type() == at::kInt, "gate_qweight has an unexpected dtype");
  TORCH_CHECK(gate_qweight.is_contiguous(), "gate_qweight must be contiguous");
  const auto bank_capacity = gate_qweight.size(0);
  validate_int4_expert_bank_tensor(gate_qscale, "gate_qscale", 3, at::kFloat, bank_capacity);
  validate_int4_expert_bank_tensor(gate_qzeros, "gate_qzeros", 3, at::kChar, bank_capacity);
  validate_int4_expert_bank_tensor(up_qweight, "up_qweight", 3, at::kInt, bank_capacity);
  validate_int4_expert_bank_tensor(up_qscale, "up_qscale", 3, at::kFloat, bank_capacity);
  validate_int4_expert_bank_tensor(up_qzeros, "up_qzeros", 3, at::kChar, bank_capacity);
  validate_int4_expert_bank_tensor(down_qweight, "down_qweight", 3, at::kInt, bank_capacity);
  validate_int4_expert_bank_tensor(down_qscale, "down_qscale", 3, at::kFloat, bank_capacity);
  validate_int4_expert_bank_tensor(down_qzeros, "down_qzeros", 3, at::kChar, bank_capacity);

  const auto hidden_dim = compact_hidden_states.size(1);
  const auto intermediate_dim = gate_qweight.size(1);
  TORCH_CHECK(bank_capacity > 0, "int4 expert bank capacity must be positive");
  TORCH_CHECK(intermediate_dim > 0, "intermediate_dim must be positive");
  TORCH_CHECK(gate_qweight.size(2) > 0, "gate_qweight packed columns must be positive");
  TORCH_CHECK(down_qweight.size(2) > 0, "down_qweight packed columns must be positive");
  TORCH_CHECK(gate_qweight.sizes() == up_qweight.sizes(), "gate/up qweight bank shape mismatch");
  TORCH_CHECK(gate_qscale.sizes() == up_qscale.sizes(), "gate/up qscale bank shape mismatch");
  TORCH_CHECK(gate_qzeros.sizes() == up_qzeros.sizes(), "gate/up qzeros bank shape mismatch");
  TORCH_CHECK(gate_qscale.size(2) == intermediate_dim, "gate_qscale output dimension mismatch");
  TORCH_CHECK(gate_qzeros.size(2) == intermediate_dim, "gate_qzeros output dimension mismatch");
  TORCH_CHECK(down_qweight.size(1) == hidden_dim, "down_qweight output dimension must match hidden_dim");
  TORCH_CHECK(down_qscale.size(2) == hidden_dim, "down_qscale output dimension mismatch");
  TORCH_CHECK(down_qzeros.size(2) == hidden_dim, "down_qzeros output dimension mismatch");
  TORCH_CHECK(gate_qweight.size(2) * 8 >= hidden_dim, "gate/up qweight packed width is smaller than hidden_dim");
  TORCH_CHECK(down_qweight.size(2) * 8 >= intermediate_dim, "down_qweight packed width is smaller than intermediate_dim");
  TORCH_CHECK(gate_qscale.size(1) * group_size >= hidden_dim, "gate/up qscale group count is smaller than hidden_dim");
  TORCH_CHECK(down_qscale.size(1) * group_size >= intermediate_dim, "down_qscale group count is smaller than intermediate_dim");
}

void validate_moe_grouped_int4_mlp_xpu_inputs(
    const at::Tensor& compact_hidden_states,
    const at::Tensor& compact_routing_weights,
    const at::Tensor& compact_outputs,
    const at::Tensor& expert_offsets,
    const at::Tensor& active_experts,
    const at::Tensor& active_slots,
    const at::Tensor& gate_qweight,
    const at::Tensor& gate_qscale,
    const at::Tensor& gate_qzeros,
    const at::Tensor& up_qweight,
    const at::Tensor& up_qscale,
    const at::Tensor& up_qzeros,
    const at::Tensor& down_qweight,
    const at::Tensor& down_qscale,
    const at::Tensor& down_qzeros) {
  auto device = compact_hidden_states.device();
  TORCH_CHECK(device.type() == c10::DeviceType::XPU, "compact_hidden_states must be an XPU tensor");
  TORCH_CHECK(compact_routing_weights.device() == device, "compact_routing_weights must be on the same device");
  TORCH_CHECK(compact_outputs.device() == device, "compact_outputs must be on the same device");
  TORCH_CHECK(expert_offsets.device() == device, "expert_offsets must be on the same device");
  TORCH_CHECK(active_experts.device() == device, "active_experts must be on the same device");
  TORCH_CHECK(active_slots.device() == device, "active_slots must be on the same device");
  TORCH_CHECK(gate_qweight.device() == device, "gate_qweight must be on the same device");
  TORCH_CHECK(gate_qscale.device() == device, "gate_qscale must be on the same device");
  TORCH_CHECK(gate_qzeros.device() == device, "gate_qzeros must be on the same device");
  TORCH_CHECK(up_qweight.device() == device, "up_qweight must be on the same device");
  TORCH_CHECK(up_qscale.device() == device, "up_qscale must be on the same device");
  TORCH_CHECK(up_qzeros.device() == device, "up_qzeros must be on the same device");
  TORCH_CHECK(down_qweight.device() == device, "down_qweight must be on the same device");
  TORCH_CHECK(down_qscale.device() == device, "down_qscale must be on the same device");
  TORCH_CHECK(down_qzeros.device() == device, "down_qzeros must be on the same device");
}

void validate_gqa_decode_inputs(
    const at::Tensor& query,
    const at::Tensor& key,
    const at::Tensor& value,
    const at::Tensor& visible_lengths) {
  TORCH_CHECK(query.dim() == 4, "query must be [batch, heads, 1, head_dim]");
  TORCH_CHECK(key.dim() == 4, "key must be [batch, kv_heads, key_len, head_dim]");
  TORCH_CHECK(value.dim() == 4, "value must be [batch, kv_heads, key_len, head_dim]");
  TORCH_CHECK(query.size(2) == 1, "gqa_decode_fused only supports single-token query");
  TORCH_CHECK(query.size(0) == key.size(0), "query/key batch size mismatch");
  TORCH_CHECK(key.sizes() == value.sizes(), "key and value must share the same shape");
  TORCH_CHECK(query.size(3) == key.size(3), "query/key head_dim mismatch");
  TORCH_CHECK(key.size(1) >= 1, "kv_heads must be positive");
  TORCH_CHECK(query.size(1) % key.size(1) == 0, "query heads must be divisible by kv_heads");
  TORCH_CHECK(key.size(2) >= 1, "key_len must be positive");
  TORCH_CHECK(visible_lengths.dim() == 1, "visible_lengths must be [batch]");
  TORCH_CHECK(visible_lengths.size(0) == query.size(0), "visible_lengths batch size mismatch");
  TORCH_CHECK(visible_lengths.scalar_type() == at::kLong, "visible_lengths must be int64");
  TORCH_CHECK(
      query.scalar_type() == key.scalar_type() && query.scalar_type() == value.scalar_type(),
      "query, key, and value must share the same dtype");
  TORCH_CHECK(
      query.scalar_type() == at::kHalf || query.scalar_type() == at::kBFloat16 ||
          query.scalar_type() == at::kFloat,
      "gqa_decode_fused XPU kernel supports float16, bfloat16, and float32 inputs");
}

void validate_gqa_decode_xpu_inputs(
    const at::Tensor& query,
    const at::Tensor& key,
    const at::Tensor& value,
    const at::Tensor& visible_lengths) {
  auto device = query.device();
  TORCH_CHECK(device.type() == c10::DeviceType::XPU, "query must be an XPU tensor");
  TORCH_CHECK(key.device() == device, "key must be on the same device as query");
  TORCH_CHECK(value.device() == device, "value must be on the same device as query");
  TORCH_CHECK(visible_lengths.device() == device, "visible_lengths must be on the same device as query");
}

void validate_gqa_decode_optional_gate(const at::Tensor& query, const c10::optional<at::Tensor>& gate_opt) {
  if (!gate_opt.has_value() || !gate_opt->defined()) {
    return;
  }
  const auto& gate = *gate_opt;
  TORCH_CHECK(gate.dim() == 3, "gqa_decode gate must be [batch, 1, num_heads * head_dim]");
  TORCH_CHECK(gate.size(0) == query.size(0), "gate batch size mismatch");
  TORCH_CHECK(gate.size(1) == 1, "gqa_decode gate expects seq_len==1 (shape [batch, 1, ...])");
  TORCH_CHECK(
      gate.size(2) == query.size(1) * query.size(3),
      "gate last dim must equal num_heads * head_dim");
  TORCH_CHECK(gate.scalar_type() == query.scalar_type(), "gate must match query dtype");
  TORCH_CHECK(gate.is_contiguous(), "gate must be contiguous");
}

void validate_paged_gqa_decode_inputs(
    const at::Tensor& query,
    const at::Tensor& key_pages,
    const at::Tensor& value_pages,
    const at::Tensor& page_table,
    const at::Tensor& visible_lengths) {
  TORCH_CHECK(query.dim() == 4, "query must be [batch, heads, 1, head_dim]");
  TORCH_CHECK(key_pages.dim() == 4, "key_pages must be [pages, kv_heads, block_size, head_dim]");
  TORCH_CHECK(value_pages.dim() == 4, "value_pages must be [pages, kv_heads, block_size, head_dim]");
  TORCH_CHECK(page_table.dim() == 2, "page_table must be [batch, max_blocks]");
  TORCH_CHECK(visible_lengths.dim() == 1, "visible_lengths must be [batch]");
  TORCH_CHECK(query.size(2) == 1, "paged_gqa_decode_fused only supports single-token query");
  TORCH_CHECK(key_pages.sizes() == value_pages.sizes(), "key_pages and value_pages must share the same shape");
  TORCH_CHECK(query.size(0) == page_table.size(0), "query/page_table batch size mismatch");
  TORCH_CHECK(query.size(0) == visible_lengths.size(0), "query/visible_lengths batch size mismatch");
  TORCH_CHECK(key_pages.size(0) >= 1, "number of pages must be positive");
  TORCH_CHECK(key_pages.size(1) >= 1, "kv_heads must be positive");
  TORCH_CHECK(key_pages.size(2) >= 1, "block_size must be positive");
  TORCH_CHECK(query.size(1) % key_pages.size(1) == 0, "query heads must be divisible by kv_heads");
  TORCH_CHECK(query.size(3) == key_pages.size(3), "query/key_pages head_dim mismatch");
  TORCH_CHECK(
      query.scalar_type() == key_pages.scalar_type() && query.scalar_type() == value_pages.scalar_type(),
      "query, key_pages, and value_pages must share the same dtype");
  TORCH_CHECK(page_table.scalar_type() == at::kInt, "page_table must be int32");
  TORCH_CHECK(visible_lengths.scalar_type() == at::kLong, "visible_lengths must be int64");
  TORCH_CHECK(
      query.scalar_type() == at::kHalf || query.scalar_type() == at::kBFloat16 ||
          query.scalar_type() == at::kFloat,
      "paged_gqa_decode_fused XPU kernel supports float16, bfloat16, and float32 inputs");
}

void validate_paged_gqa_decode_xpu_inputs(
    const at::Tensor& query,
    const at::Tensor& key_pages,
    const at::Tensor& value_pages,
    const at::Tensor& page_table,
    const at::Tensor& visible_lengths) {
  auto device = query.device();
  TORCH_CHECK(device.type() == c10::DeviceType::XPU, "query must be an XPU tensor");
  TORCH_CHECK(key_pages.device() == device, "key_pages must be on the same device as query");
  TORCH_CHECK(value_pages.device() == device, "value_pages must be on the same device as query");
  TORCH_CHECK(page_table.device() == device, "page_table must be on the same device as query");
  TORCH_CHECK(visible_lengths.device() == device, "visible_lengths must be on the same device as query");
}

void validate_causal_conv_inputs(
    const at::Tensor& hidden_states,
    const at::Tensor& conv_state,
    const at::Tensor& weight,
    const c10::optional<at::Tensor>& bias_opt) {
  TORCH_CHECK(hidden_states.dim() == 3, "hidden_states must be [batch, channels, seq_len]");
  TORCH_CHECK(conv_state.dim() == 3, "conv_state must be [batch, channels, kernel_size]");
  TORCH_CHECK(weight.dim() == 2, "weight must be [channels, kernel_size]");
  TORCH_CHECK(hidden_states.size(0) == conv_state.size(0), "hidden_states/conv_state batch size mismatch");
  TORCH_CHECK(hidden_states.size(1) == conv_state.size(1), "hidden_states/conv_state channel count mismatch");
  TORCH_CHECK(hidden_states.size(1) == weight.size(0), "hidden_states/weight channel count mismatch");
  TORCH_CHECK(conv_state.size(2) == weight.size(1), "conv_state length must match kernel size");
  TORCH_CHECK(hidden_states.size(2) >= 1, "hidden_states sequence length must be positive");
  TORCH_CHECK(conv_state.size(2) >= 1, "kernel size must be positive");
  TORCH_CHECK(
      hidden_states.scalar_type() == conv_state.scalar_type() &&
          hidden_states.scalar_type() == weight.scalar_type(),
      "hidden_states, conv_state, and weight must share the same dtype");
  TORCH_CHECK(
      hidden_states.scalar_type() == at::kHalf || hidden_states.scalar_type() == at::kBFloat16 ||
          hidden_states.scalar_type() == at::kFloat,
      "causal_conv1d_fused XPU kernel supports float16, bfloat16, and float32 inputs");

  if (bias_opt.has_value() && bias_opt->defined()) {
    TORCH_CHECK(bias_opt->dim() == 1, "bias must be [channels]");
    TORCH_CHECK(bias_opt->size(0) == hidden_states.size(1), "bias size must match channel count");
    TORCH_CHECK(bias_opt->scalar_type() == hidden_states.scalar_type(), "bias dtype must match hidden_states");
  }
}

void validate_causal_conv_xpu_inputs(
    const at::Tensor& hidden_states,
    const at::Tensor& conv_state,
    const at::Tensor& weight,
    const c10::optional<at::Tensor>& bias_opt) {
  auto device = hidden_states.device();
  TORCH_CHECK(device.type() == c10::DeviceType::XPU, "hidden_states must be an XPU tensor");
  TORCH_CHECK(conv_state.device() == device, "conv_state must be on the same device as hidden_states");
  TORCH_CHECK(weight.device() == device, "weight must be on the same device as hidden_states");
  if (bias_opt.has_value() && bias_opt->defined()) {
    TORCH_CHECK(bias_opt->device() == device, "bias must be on the same device as hidden_states");
    TORCH_CHECK(bias_opt->is_contiguous(), "bias must be contiguous");
  }
  TORCH_CHECK(hidden_states.is_contiguous(), "hidden_states must be contiguous");
  TORCH_CHECK(conv_state.is_contiguous(), "conv_state must be contiguous");
  TORCH_CHECK(weight.is_contiguous(), "weight must be contiguous");
}

template <typename scalar_t>
void launch_causal_conv1d_prefill_kernel(
    sycl::queue& queue,
    const scalar_t* hidden_ptr,
    const scalar_t* state_read_ptr,
    scalar_t* state_write_ptr,
    const scalar_t* weight_ptr,
    const scalar_t* bias_ptr,
    bool has_bias,
    scalar_t* output_ptr,
    int64_t batch_size,
    int64_t channels,
    int64_t sequence_length,
    int64_t kernel_size) {
  const int64_t total_outputs = batch_size * channels * sequence_length;
  const int64_t total_states = batch_size * channels;

  queue.submit([&](sycl::handler& cgh) {
    cgh.parallel_for(sycl::range<1>(static_cast<size_t>(total_outputs)), [=](sycl::item<1> item) {
      const int64_t linear_idx = static_cast<int64_t>(item.get_id(0));
      const int64_t t = linear_idx % sequence_length;
      const int64_t batch_channel = linear_idx / sequence_length;
      const int64_t b = batch_channel / channels;
      const int64_t c = batch_channel % channels;
      const int64_t hidden_base = (b * channels + c) * sequence_length;
      const int64_t state_base = (b * channels + c) * kernel_size;
      const int64_t weight_base = c * kernel_size;

      float acc = has_bias ? load_as_float(bias_ptr, c) : 0.0f;
      for (int64_t k = 0; k < kernel_size; ++k) {
        const int64_t source_index = t + 1 + k;
        const float input_value = source_index < kernel_size
            ? load_as_float(state_read_ptr, state_base + source_index)
            : load_as_float(hidden_ptr, hidden_base + (source_index - kernel_size));
        acc += input_value * load_as_float(weight_ptr, weight_base + k);
      }

      const float silu = acc / (1.0f + sycl::exp(-acc));
      output_ptr[hidden_base + t] = static_cast<scalar_t>(silu);
    });
  });

  queue.submit([&](sycl::handler& cgh) {
    cgh.parallel_for(sycl::range<1>(static_cast<size_t>(total_states)), [=](sycl::item<1> item) {
      const int64_t batch_channel = static_cast<int64_t>(item.get_id(0));
      const int64_t b = batch_channel / channels;
      const int64_t c = batch_channel % channels;
      const int64_t hidden_base = (b * channels + c) * sequence_length;
      const int64_t state_base = (b * channels + c) * kernel_size;

      if (sequence_length >= kernel_size) {
        for (int64_t k = 0; k < kernel_size; ++k) {
          state_write_ptr[state_base + k] = hidden_ptr[hidden_base + (sequence_length - kernel_size + k)];
        }
        return;
      }

      const int64_t retained = kernel_size - sequence_length;
      for (int64_t k = 0; k < retained; ++k) {
        state_write_ptr[state_base + k] = state_read_ptr[state_base + sequence_length + k];
      }
      for (int64_t k = 0; k < sequence_length; ++k) {
        state_write_ptr[state_base + retained + k] = hidden_ptr[hidden_base + k];
      }
    });
  });
}

template <typename scalar_t>
void launch_causal_conv1d_decode_kernel(
    sycl::queue& queue,
    const scalar_t* hidden_ptr,
    const scalar_t* state_read_ptr,
    scalar_t* state_write_ptr,
    const scalar_t* weight_ptr,
    const scalar_t* bias_ptr,
    bool has_bias,
    scalar_t* output_ptr,
    int64_t batch_size,
    int64_t channels,
    int64_t kernel_size) {
  const int64_t total_channels = batch_size * channels;

  queue.submit([&](sycl::handler& cgh) {
    cgh.parallel_for(sycl::range<1>(static_cast<size_t>(total_channels)), [=](sycl::item<1> item) {
      const int64_t batch_channel = static_cast<int64_t>(item.get_id(0));
      const int64_t b = batch_channel / channels;
      const int64_t c = batch_channel % channels;
      const int64_t hidden_base = batch_channel;
      const int64_t state_base = batch_channel * kernel_size;
      const int64_t weight_base = c * kernel_size;

      float acc = has_bias ? load_as_float(bias_ptr, c) : 0.0f;
      for (int64_t k = 0; k < kernel_size; ++k) {
        const float input_value = k + 1 < kernel_size
            ? load_as_float(state_read_ptr, state_base + k + 1)
            : load_as_float(hidden_ptr, hidden_base);
        acc += input_value * load_as_float(weight_ptr, weight_base + k);
      }

      const float silu = acc / (1.0f + sycl::exp(-acc));
      output_ptr[hidden_base] = static_cast<scalar_t>(silu);

      for (int64_t k = 0; k < kernel_size - 1; ++k) {
        state_write_ptr[state_base + k] = state_read_ptr[state_base + k + 1];
      }
      state_write_ptr[state_base + kernel_size - 1] = hidden_ptr[hidden_base];
    });
  });
}

std::tuple<at::Tensor, at::Tensor> causal_conv1d_prefill_meta(
    const at::Tensor& hidden_states,
    const at::Tensor& conv_state,
    const at::Tensor& weight,
    const c10::optional<at::Tensor>& bias_opt) {
  validate_causal_conv_inputs(hidden_states, conv_state, weight, bias_opt);
  TORCH_CHECK(hidden_states.size(2) > 1, "causal_conv1d_prefill expects seq_len > 1");
  auto meta_options = hidden_states.options().device(c10::Device(c10::DeviceType::Meta));
  return {
      at::empty(hidden_states.sizes(), meta_options),
      at::empty(conv_state.sizes(), meta_options),
  };
}

at::Tensor causal_conv1d_decode_meta(
    const at::Tensor& hidden_states,
    const at::Tensor& conv_state,
    const at::Tensor& weight,
    const c10::optional<at::Tensor>& bias_opt) {
  validate_causal_conv_inputs(hidden_states, conv_state, weight, bias_opt);
  TORCH_CHECK(hidden_states.size(2) == 1, "causal_conv1d_decode expects seq_len == 1");
  auto meta_options = hidden_states.options().device(c10::Device(c10::DeviceType::Meta));
  return at::empty(hidden_states.sizes(), meta_options);
}

std::tuple<at::Tensor, at::Tensor> causal_conv1d_prefill_xpu(
    const at::Tensor& hidden_states,
    const at::Tensor& conv_state,
    const at::Tensor& weight,
    const c10::optional<at::Tensor>& bias_opt) {
  validate_causal_conv_inputs(hidden_states, conv_state, weight, bias_opt);
  validate_causal_conv_xpu_inputs(hidden_states, conv_state, weight, bias_opt);
  TORCH_CHECK(hidden_states.size(2) > 1, "causal_conv1d_prefill expects seq_len > 1");

  const auto batch_size = hidden_states.size(0);
  const auto channels = hidden_states.size(1);
  const auto sequence_length = hidden_states.size(2);
  const auto kernel_size = weight.size(1);

  auto output = at::empty(hidden_states.sizes(), hidden_states.options());
  auto final_state = at::empty(conv_state.sizes(), conv_state.options());
  auto stream = c10::xpu::getCurrentXPUStream(hidden_states.device().index());

  AT_DISPATCH_FLOATING_TYPES_AND2(
      at::kHalf,
      at::kBFloat16,
      hidden_states.scalar_type(),
      "causal_conv1d_prefill_xpu",
      [&] {
        const scalar_t* hidden_ptr = hidden_states.const_data_ptr<scalar_t>();
        const scalar_t* state_read_ptr = conv_state.const_data_ptr<scalar_t>();
        scalar_t* state_write_ptr = final_state.mutable_data_ptr<scalar_t>();
        const scalar_t* weight_ptr = weight.const_data_ptr<scalar_t>();
        const bool has_bias = bias_opt.has_value() && bias_opt->defined();
        const scalar_t* bias_ptr = has_bias ? bias_opt->const_data_ptr<scalar_t>() : nullptr;
        scalar_t* output_ptr = output.mutable_data_ptr<scalar_t>();
        launch_causal_conv1d_prefill_kernel(
            stream.queue(),
            hidden_ptr,
            state_read_ptr,
            state_write_ptr,
            weight_ptr,
            bias_ptr,
            has_bias,
            output_ptr,
            batch_size,
            channels,
            sequence_length,
            kernel_size);
      });

  return {output, final_state};
}

at::Tensor causal_conv1d_decode_xpu(
    const at::Tensor& hidden_states,
    const at::Tensor& conv_state,
    const at::Tensor& weight,
    const c10::optional<at::Tensor>& bias_opt) {
  validate_causal_conv_inputs(hidden_states, conv_state, weight, bias_opt);
  validate_causal_conv_xpu_inputs(hidden_states, conv_state, weight, bias_opt);
  TORCH_CHECK(hidden_states.size(2) == 1, "causal_conv1d_decode expects seq_len == 1");

  const auto batch_size = hidden_states.size(0);
  const auto channels = hidden_states.size(1);
  const auto kernel_size = weight.size(1);

  auto output = at::empty(hidden_states.sizes(), hidden_states.options());
  auto stream = c10::xpu::getCurrentXPUStream(hidden_states.device().index());

  AT_DISPATCH_FLOATING_TYPES_AND2(
      at::kHalf,
      at::kBFloat16,
      hidden_states.scalar_type(),
      "causal_conv1d_decode_xpu",
      [&] {
        const scalar_t* hidden_ptr = hidden_states.const_data_ptr<scalar_t>();
        const scalar_t* state_read_ptr = conv_state.const_data_ptr<scalar_t>();
        scalar_t* state_write_ptr = conv_state.mutable_data_ptr<scalar_t>();
        const scalar_t* weight_ptr = weight.const_data_ptr<scalar_t>();
        const bool has_bias = bias_opt.has_value() && bias_opt->defined();
        const scalar_t* bias_ptr = has_bias ? bias_opt->const_data_ptr<scalar_t>() : nullptr;
        scalar_t* output_ptr = output.mutable_data_ptr<scalar_t>();

        launch_causal_conv1d_decode_kernel(
            stream.queue(),
            hidden_ptr,
            state_read_ptr,
            state_write_ptr,
            weight_ptr,
            bias_ptr,
            has_bias,
            output_ptr,
            batch_size,
            channels,
            kernel_size);
      });

  return output;
}

at::Tensor rmsnorm_fused_meta(
    const at::Tensor& input,
    const at::Tensor& weight,
    double /*eps*/) {
  validate_rmsnorm_inputs(input, weight);
  auto meta_options = input.options().device(c10::Device(c10::DeviceType::Meta));
  return at::empty(input.sizes(), meta_options);
}

at::Tensor rmsnorm_fused_ex_meta(
    const at::Tensor& input,
    const at::Tensor& weight,
    double /*eps*/,
    bool /*add_unit_offset*/) {
  validate_rmsnorm_inputs(input, weight);
  auto meta_options = input.options().device(c10::Device(c10::DeviceType::Meta));
  return at::empty(input.sizes(), meta_options);
}

at::Tensor rmsnorm_gated_fused_meta(
    const at::Tensor& input,
    const at::Tensor& gate,
    const at::Tensor& weight,
    double /*eps*/) {
  validate_rmsnorm_gated_inputs(input, gate, weight);
  auto meta_options = input.options().device(c10::Device(c10::DeviceType::Meta));
  return at::empty(input.sizes(), meta_options);
}

template <bool AddUnitOffset>
at::Tensor rmsnorm_fused_xpu_impl(
    const at::Tensor& input_in,
    const at::Tensor& weight_in,
    double eps) {
  validate_rmsnorm_inputs(input_in, weight_in);
  validate_rmsnorm_xpu_inputs(input_in, weight_in);

  auto input = input_in.contiguous();
  auto weight = weight_in.to(at::kFloat).contiguous();
  auto output = at::empty(input.sizes(), input.options());

  const auto hidden_size = input.size(-1);
  const auto row_count = input.numel() / hidden_size;
  const int64_t local_size =
      std::min<int64_t>(next_power_of_two(std::max<int64_t>(1, std::min<int64_t>(hidden_size, 256))), 256);
  const float eps_f = static_cast<float>(eps);
  auto stream = c10::xpu::getCurrentXPUStream(input.device().index());

  AT_DISPATCH_FLOATING_TYPES_AND2(
      at::kHalf,
      at::kBFloat16,
      input.scalar_type(),
      "rmsnorm_fused_xpu",
      [&] {
        const scalar_t* input_ptr = input.const_data_ptr<scalar_t>();
        const float* weight_ptr = weight.const_data_ptr<float>();
        scalar_t* output_ptr = output.mutable_data_ptr<scalar_t>();

        stream.queue().submit([&](sycl::handler& cgh) {
          sycl::local_accessor<float, 1> partial_sum(sycl::range<1>(static_cast<size_t>(local_size)), cgh);
          cgh.parallel_for(
              sycl::nd_range<2>(
                  sycl::range<2>(static_cast<size_t>(row_count), static_cast<size_t>(local_size)),
                  sycl::range<2>(1, static_cast<size_t>(local_size))),
              [=](sycl::nd_item<2> item) {
                const int64_t row = static_cast<int64_t>(item.get_group(0));
                const int64_t lane = static_cast<int64_t>(item.get_local_id(1));
                const int64_t row_base = row * hidden_size;

                float local_sum_sq = 0.0f;
                for (int64_t idx = lane; idx < hidden_size; idx += local_size) {
                  const float value = load_as_float(input_ptr, row_base + idx);
                  local_sum_sq += value * value;
                }

                partial_sum[lane] = local_sum_sq;
                item.barrier(sycl::access::fence_space::local_space);

                for (int64_t stride = local_size / 2; stride > 0; stride >>= 1) {
                  if (lane < stride) {
                    partial_sum[lane] += partial_sum[lane + stride];
                  }
                  item.barrier(sycl::access::fence_space::local_space);
                }

                const float inv_rms = sycl::rsqrt(partial_sum[0] / static_cast<float>(hidden_size) + eps_f);
                for (int64_t idx = lane; idx < hidden_size; idx += local_size) {
                  const float value = load_as_float(input_ptr, row_base + idx);
                  const float weight_value = AddUnitOffset ? (1.0f + weight_ptr[idx]) : weight_ptr[idx];
                  const float scaled = value * inv_rms * weight_value;
                  output_ptr[row_base + idx] = static_cast<scalar_t>(scaled);
                }
              });
        });
      });

  return output;
}

at::Tensor rmsnorm_gated_fused_xpu(
    const at::Tensor& input_in,
    const at::Tensor& gate_in,
    const at::Tensor& weight_in,
    double eps) {
  validate_rmsnorm_gated_inputs(input_in, gate_in, weight_in);
  validate_rmsnorm_gated_xpu_inputs(input_in, gate_in, weight_in);

  auto input = input_in.contiguous();
  auto gate = gate_in.contiguous();
  auto weight = weight_in.to(at::kFloat).contiguous();
  auto output = at::empty(input.sizes(), input.options());

  const auto hidden_size = input.size(-1);
  const auto row_count = input.numel() / hidden_size;
  const int64_t local_size =
      std::min<int64_t>(next_power_of_two(std::max<int64_t>(1, std::min<int64_t>(hidden_size, 256))), 256);
  const float eps_f = static_cast<float>(eps);
  auto stream = c10::xpu::getCurrentXPUStream(input.device().index());

  AT_DISPATCH_FLOATING_TYPES_AND2(
      at::kHalf,
      at::kBFloat16,
      input.scalar_type(),
      "rmsnorm_gated_fused_xpu",
      [&] {
        const scalar_t* input_ptr = input.const_data_ptr<scalar_t>();
        const scalar_t* gate_ptr = gate.const_data_ptr<scalar_t>();
        const float* weight_ptr = weight.const_data_ptr<float>();
        scalar_t* output_ptr = output.mutable_data_ptr<scalar_t>();

        stream.queue().submit([&](sycl::handler& cgh) {
          sycl::local_accessor<float, 1> partial_sum(sycl::range<1>(static_cast<size_t>(local_size)), cgh);
          cgh.parallel_for(
              sycl::nd_range<2>(
                  sycl::range<2>(static_cast<size_t>(row_count), static_cast<size_t>(local_size)),
                  sycl::range<2>(1, static_cast<size_t>(local_size))),
              [=](sycl::nd_item<2> item) {
                const int64_t row = static_cast<int64_t>(item.get_group(0));
                const int64_t lane = static_cast<int64_t>(item.get_local_id(1));
                const int64_t row_base = row * hidden_size;

                float local_sum_sq = 0.0f;
                for (int64_t idx = lane; idx < hidden_size; idx += local_size) {
                  const float value = load_as_float(input_ptr, row_base + idx);
                  local_sum_sq += value * value;
                }

                partial_sum[lane] = local_sum_sq;
                item.barrier(sycl::access::fence_space::local_space);

                for (int64_t stride = local_size / 2; stride > 0; stride >>= 1) {
                  if (lane < stride) {
                    partial_sum[lane] += partial_sum[lane + stride];
                  }
                  item.barrier(sycl::access::fence_space::local_space);
                }

                const float inv_rms = sycl::rsqrt(partial_sum[0] / static_cast<float>(hidden_size) + eps_f);
                for (int64_t idx = lane; idx < hidden_size; idx += local_size) {
                  const int64_t offset = row_base + idx;
                  const float value = load_as_float(input_ptr, offset);
                  const float gate_value = load_as_float(gate_ptr, offset);
                  const float silu_gate = gate_value / (1.0f + sycl::exp(-gate_value));
                  const float scaled = value * inv_rms * weight_ptr[idx] * silu_gate;
                  output_ptr[offset] = static_cast<scalar_t>(scaled);
                }
              });
        });
      });

  return output;
}

at::Tensor rmsnorm_fused_xpu(
    const at::Tensor& input_in,
    const at::Tensor& weight_in,
    double eps) {
  return rmsnorm_fused_xpu_impl<true>(input_in, weight_in, eps);
}

at::Tensor rmsnorm_fused_ex_xpu(
    const at::Tensor& input_in,
    const at::Tensor& weight_in,
    double eps,
    bool add_unit_offset) {
  if (add_unit_offset) {
    return rmsnorm_fused_xpu_impl<true>(input_in, weight_in, eps);
  }
  return rmsnorm_fused_xpu_impl<false>(input_in, weight_in, eps);
}

std::tuple<at::Tensor, at::Tensor> qk_norm_rotary_fused_meta(
    const at::Tensor& query,
    const at::Tensor& key,
    const at::Tensor& query_norm_weight,
    const at::Tensor& key_norm_weight,
    const at::Tensor& cos,
    const at::Tensor& sin,
    double /*query_norm_eps*/,
    double /*key_norm_eps*/) {
  validate_qk_norm_rotary_inputs(query, key, query_norm_weight, key_norm_weight, cos, sin);
  auto meta_options = query.options().device(c10::Device(c10::DeviceType::Meta));
  return {
      at::empty(query.sizes(), meta_options),
      at::empty(key.sizes(), meta_options),
  };
}

std::tuple<at::Tensor, at::Tensor> qk_norm_rotary_fused_ex_meta(
    const at::Tensor& query,
    const at::Tensor& key,
    const at::Tensor& query_norm_weight,
    const at::Tensor& key_norm_weight,
    const at::Tensor& cos,
    const at::Tensor& sin,
    double /*query_norm_eps*/,
    double /*key_norm_eps*/,
    bool /*add_unit_offset*/) {
  validate_qk_norm_rotary_inputs(query, key, query_norm_weight, key_norm_weight, cos, sin);
  auto meta_options = query.options().device(c10::Device(c10::DeviceType::Meta));
  return {
      at::empty(query.sizes(), meta_options),
      at::empty(key.sizes(), meta_options),
  };
}

template <bool AddUnitOffset>
std::tuple<at::Tensor, at::Tensor> qk_norm_rotary_fused_xpu_impl(
    const at::Tensor& query_in,
    const at::Tensor& key_in,
    const at::Tensor& query_norm_weight_in,
    const at::Tensor& key_norm_weight_in,
    const at::Tensor& cos_in,
    const at::Tensor& sin_in,
    double query_norm_eps,
    double key_norm_eps) {
  validate_qk_norm_rotary_inputs(query_in, key_in, query_norm_weight_in, key_norm_weight_in, cos_in, sin_in);
  validate_qk_norm_rotary_xpu_inputs(query_in, key_in, query_norm_weight_in, key_norm_weight_in, cos_in, sin_in);

  auto query = query_in.contiguous();
  auto key = key_in.contiguous();
  auto query_norm_weight = query_norm_weight_in.to(at::kFloat).contiguous();
  auto key_norm_weight = key_norm_weight_in.to(at::kFloat).contiguous();
  auto cos = cos_in.to(at::kFloat).contiguous();
  auto sin = sin_in.to(at::kFloat).contiguous();
  auto query_output = at::empty(query.sizes(), query.options());
  auto key_output = at::empty(key.sizes(), key.options());

  const auto batch_size = query.size(0);
  const auto sequence_length = query.size(2);
  const auto head_dim = query.size(3);
  const auto query_num_heads = query.size(1);
  const auto key_num_heads = key.size(1);
  const auto total_num_heads = query_num_heads + key_num_heads;
  const auto rotary_dim = cos.size(2);
  const int64_t local_size =
      std::min<int64_t>(next_power_of_two(std::max<int64_t>(1, std::min<int64_t>(head_dim, 256))), 256);
  const float query_norm_eps_f = static_cast<float>(query_norm_eps);
  const float key_norm_eps_f = static_cast<float>(key_norm_eps);
  auto stream = c10::xpu::getCurrentXPUStream(query.device().index());

  AT_DISPATCH_FLOATING_TYPES_AND2(
      at::kHalf,
      at::kBFloat16,
      query.scalar_type(),
      "qk_norm_rotary_fused_xpu",
      [&] {
        const scalar_t* query_ptr = query.const_data_ptr<scalar_t>();
        const scalar_t* key_ptr = key.const_data_ptr<scalar_t>();
        const float* query_weight_ptr = query_norm_weight.const_data_ptr<float>();
        const float* key_weight_ptr = key_norm_weight.const_data_ptr<float>();
        const float* cos_ptr = cos.const_data_ptr<float>();
        const float* sin_ptr = sin.const_data_ptr<float>();
        scalar_t* query_output_ptr = query_output.mutable_data_ptr<scalar_t>();
        scalar_t* key_output_ptr = key_output.mutable_data_ptr<scalar_t>();
        const size_t group_count =
            static_cast<size_t>(batch_size) * static_cast<size_t>(total_num_heads) * static_cast<size_t>(sequence_length);

        stream.queue().submit([&](sycl::handler& cgh) {
          sycl::local_accessor<float, 1> partial_sum(sycl::range<1>(static_cast<size_t>(local_size)), cgh);
          sycl::local_accessor<float, 1> normalized_values(sycl::range<1>(static_cast<size_t>(head_dim)), cgh);
          cgh.parallel_for(
              sycl::nd_range<2>(
                  sycl::range<2>(group_count, static_cast<size_t>(local_size)),
                  sycl::range<2>(1, static_cast<size_t>(local_size))),
              [=](sycl::nd_item<2> item) {
                const int64_t row = static_cast<int64_t>(item.get_group(0));
                const int64_t lane = static_cast<int64_t>(item.get_local_id(1));
                const int64_t sequence_idx = row % sequence_length;
                const int64_t batch_head = row / sequence_length;
                const int64_t combined_head_idx = batch_head % total_num_heads;
                const int64_t batch_idx = batch_head / total_num_heads;
                const bool is_query = combined_head_idx < query_num_heads;
                const int64_t head_idx = is_query ? combined_head_idx : (combined_head_idx - query_num_heads);
                const int64_t num_heads = is_query ? query_num_heads : key_num_heads;
                const scalar_t* input_ptr = is_query ? query_ptr : key_ptr;
                const float* weight_ptr = is_query ? query_weight_ptr : key_weight_ptr;
                scalar_t* output_ptr = is_query ? query_output_ptr : key_output_ptr;
                const float norm_eps_f = is_query ? query_norm_eps_f : key_norm_eps_f;
                const int64_t row_base =
                    (((batch_idx * num_heads) + head_idx) * sequence_length + sequence_idx) * head_dim;
                const int64_t trig_base = (batch_idx * sequence_length + sequence_idx) * rotary_dim;

                float local_sum_sq = 0.0f;
                for (int64_t idx = lane; idx < head_dim; idx += local_size) {
                  const float value = load_as_float(input_ptr, row_base + idx);
                  local_sum_sq += value * value;
                }

                partial_sum[lane] = local_sum_sq;
                item.barrier(sycl::access::fence_space::local_space);

                for (int64_t stride = local_size / 2; stride > 0; stride >>= 1) {
                  if (lane < stride) {
                    partial_sum[lane] += partial_sum[lane + stride];
                  }
                  item.barrier(sycl::access::fence_space::local_space);
                }

                const float inv_rms = sycl::rsqrt(partial_sum[0] / static_cast<float>(head_dim) + norm_eps_f);
                for (int64_t idx = lane; idx < head_dim; idx += local_size) {
                  const float value = load_as_float(input_ptr, row_base + idx);
                  const float weight_value = AddUnitOffset ? (1.0f + weight_ptr[idx]) : weight_ptr[idx];
                  normalized_values[idx] = value * inv_rms * weight_value;
                }
                item.barrier(sycl::access::fence_space::local_space);

                const int64_t half_rotary_dim = rotary_dim / 2;
                for (int64_t idx = lane; idx < head_dim; idx += local_size) {
                  float output_value = normalized_values[idx];
                  if (idx < rotary_dim) {
                    const float rotated = idx < half_rotary_dim
                        ? -normalized_values[idx + half_rotary_dim]
                        : normalized_values[idx - half_rotary_dim];
                    output_value =
                        normalized_values[idx] * cos_ptr[trig_base + idx] + rotated * sin_ptr[trig_base + idx];
                  }
                  output_ptr[row_base + idx] = static_cast<scalar_t>(output_value);
                }
              });
        });
      });

  return {query_output, key_output};
}

std::tuple<at::Tensor, at::Tensor> qk_norm_rotary_fused_xpu(
    const at::Tensor& query_in,
    const at::Tensor& key_in,
    const at::Tensor& query_norm_weight_in,
    const at::Tensor& key_norm_weight_in,
    const at::Tensor& cos_in,
    const at::Tensor& sin_in,
    double query_norm_eps,
    double key_norm_eps) {
  return qk_norm_rotary_fused_xpu_impl<true>(
      query_in,
      key_in,
      query_norm_weight_in,
      key_norm_weight_in,
      cos_in,
      sin_in,
      query_norm_eps,
      key_norm_eps);
}

std::tuple<at::Tensor, at::Tensor> qk_norm_rotary_fused_ex_xpu(
    const at::Tensor& query_in,
    const at::Tensor& key_in,
    const at::Tensor& query_norm_weight_in,
    const at::Tensor& key_norm_weight_in,
    const at::Tensor& cos_in,
    const at::Tensor& sin_in,
    double query_norm_eps,
    double key_norm_eps,
    bool add_unit_offset) {
  if (add_unit_offset) {
    return qk_norm_rotary_fused_xpu_impl<true>(
        query_in,
        key_in,
        query_norm_weight_in,
        key_norm_weight_in,
        cos_in,
        sin_in,
        query_norm_eps,
        key_norm_eps);
  }
  return qk_norm_rotary_fused_xpu_impl<false>(
      query_in,
      key_in,
      query_norm_weight_in,
      key_norm_weight_in,
      cos_in,
      sin_in,
      query_norm_eps,
      key_norm_eps);
}

std::tuple<at::Tensor, at::Tensor, at::Tensor> moe_router_fused_meta(
    const at::Tensor& router_logits,
    int64_t top_k,
    bool /*normalize_topk_prob*/) {
  validate_moe_router_inputs(router_logits, top_k);
  auto weights_options = router_logits.options().device(c10::Device(c10::DeviceType::Meta)).dtype(at::kFloat);
  auto index_options = router_logits.options().device(c10::Device(c10::DeviceType::Meta)).dtype(at::kLong);
  auto usage_options = router_logits.options().device(c10::Device(c10::DeviceType::Meta)).dtype(at::kInt);
  return {
      at::empty({router_logits.size(0), top_k}, weights_options),
      at::empty({router_logits.size(0), top_k}, index_options),
      at::empty({router_logits.size(1)}, usage_options),
  };
}

std::tuple<at::Tensor, at::Tensor, at::Tensor> moe_router_fused_xpu(
    const at::Tensor& router_logits_in,
    int64_t top_k,
    bool normalize_topk_prob) {
  validate_moe_router_inputs(router_logits_in, top_k);
  validate_moe_router_xpu_inputs(router_logits_in);

  auto router_logits = router_logits_in.contiguous();
  const auto tokens = router_logits.size(0);
  const auto num_experts = router_logits.size(1);
  const int64_t local_size = std::min<int64_t>(next_power_of_two(std::max<int64_t>(1, num_experts)), 256);

  auto routing_weights = at::empty({tokens, top_k}, router_logits.options().dtype(at::kFloat));
  auto selected_experts = at::empty({tokens, top_k}, router_logits.options().dtype(at::kLong));
  auto expert_usage = at::zeros({num_experts}, router_logits.options().dtype(at::kInt));
  auto stream = c10::xpu::getCurrentXPUStream(router_logits.device().index());

  AT_DISPATCH_FLOATING_TYPES_AND2(
      at::kHalf,
      at::kBFloat16,
      router_logits.scalar_type(),
      "moe_router_fused_xpu",
      [&] {
        const scalar_t* logits_ptr = router_logits.const_data_ptr<scalar_t>();
        float* routing_weights_ptr = routing_weights.mutable_data_ptr<float>();
        int64_t* selected_experts_ptr = selected_experts.mutable_data_ptr<int64_t>();
        int32_t* expert_usage_ptr = expert_usage.mutable_data_ptr<int32_t>();
        const bool normalize_topk_prob_value = normalize_topk_prob;

        stream.queue().submit([&](sycl::handler& cgh) {
          sycl::local_accessor<float, 1> partial_max(sycl::range<1>(static_cast<size_t>(local_size)), cgh);
          sycl::local_accessor<float, 1> partial_sum(sycl::range<1>(static_cast<size_t>(local_size)), cgh);
          sycl::local_accessor<float, 1> probabilities(sycl::range<1>(static_cast<size_t>(num_experts)), cgh);
          sycl::local_accessor<float, 1> top_values(sycl::range<1>(static_cast<size_t>(top_k)), cgh);
          sycl::local_accessor<int64_t, 1> top_indices(sycl::range<1>(static_cast<size_t>(top_k)), cgh);

          cgh.parallel_for(
              sycl::nd_range<2>(
                  sycl::range<2>(static_cast<size_t>(tokens), static_cast<size_t>(local_size)),
                  sycl::range<2>(1, static_cast<size_t>(local_size))),
              [=](sycl::nd_item<2> item) {
                const int64_t token_idx = static_cast<int64_t>(item.get_group(0));
                const int64_t lane = static_cast<int64_t>(item.get_local_id(1));
                const int64_t row_base = token_idx * num_experts;

                float local_max = -std::numeric_limits<float>::infinity();
                for (int64_t expert_idx = lane; expert_idx < num_experts; expert_idx += local_size) {
                  const float value = load_as_float(logits_ptr, row_base + expert_idx);
                  local_max = sycl::fmax(local_max, value);
                }
                partial_max[lane] = local_max;
                item.barrier(sycl::access::fence_space::local_space);

                for (int64_t stride = local_size / 2; stride > 0; stride >>= 1) {
                  if (lane < stride) {
                    partial_max[lane] = sycl::fmax(partial_max[lane], partial_max[lane + stride]);
                  }
                  item.barrier(sycl::access::fence_space::local_space);
                }

                const float max_value = partial_max[0];
                float local_sum = 0.0f;
                for (int64_t expert_idx = lane; expert_idx < num_experts; expert_idx += local_size) {
                  const float exp_value = sycl::exp(load_as_float(logits_ptr, row_base + expert_idx) - max_value);
                  probabilities[expert_idx] = exp_value;
                  local_sum += exp_value;
                }
                partial_sum[lane] = local_sum;
                item.barrier(sycl::access::fence_space::local_space);

                for (int64_t stride = local_size / 2; stride > 0; stride >>= 1) {
                  if (lane < stride) {
                    partial_sum[lane] += partial_sum[lane + stride];
                  }
                  item.barrier(sycl::access::fence_space::local_space);
                }

                const float inv_sum = 1.0f / partial_sum[0];
                for (int64_t expert_idx = lane; expert_idx < num_experts; expert_idx += local_size) {
                  probabilities[expert_idx] *= inv_sum;
                }
                item.barrier(sycl::access::fence_space::local_space);

                if (lane == 0) {
                  for (int64_t route_idx = 0; route_idx < top_k; ++route_idx) {
                    top_values[route_idx] = -std::numeric_limits<float>::infinity();
                    top_indices[route_idx] = 0;
                  }

                  for (int64_t expert_idx = 0; expert_idx < num_experts; ++expert_idx) {
                    const float prob = probabilities[expert_idx];
                    if (prob <= top_values[top_k - 1]) {
                      continue;
                    }
                    int64_t insert_idx = top_k - 1;
                    while (insert_idx > 0 && prob > top_values[insert_idx - 1]) {
                      top_values[insert_idx] = top_values[insert_idx - 1];
                      top_indices[insert_idx] = top_indices[insert_idx - 1];
                      --insert_idx;
                    }
                    top_values[insert_idx] = prob;
                    top_indices[insert_idx] = expert_idx;
                  }

                  float top_sum = 0.0f;
                  for (int64_t route_idx = 0; route_idx < top_k; ++route_idx) {
                    top_sum += top_values[route_idx];
                  }
                  const float renorm_scale = normalize_topk_prob_value && top_sum > 0.0f ? 1.0f / top_sum : 1.0f;
                  const int64_t out_base = token_idx * top_k;
                  for (int64_t route_idx = 0; route_idx < top_k; ++route_idx) {
                    const int64_t expert_idx = top_indices[route_idx];
                    routing_weights_ptr[out_base + route_idx] = top_values[route_idx] * renorm_scale;
                    selected_experts_ptr[out_base + route_idx] = expert_idx;
                    sycl::atomic_ref<
                        int32_t,
                        sycl::memory_order::relaxed,
                        sycl::memory_scope::device,
                        sycl::access::address_space::global_space>(expert_usage_ptr[expert_idx])
                        .fetch_add(1);
                  }
                }
              });
        });
      });

  return {routing_weights, selected_experts, expert_usage};
}

std::tuple<at::Tensor, at::Tensor, at::Tensor, at::Tensor> moe_dispatch_fused_meta(
    const at::Tensor& hidden_states,
    const at::Tensor& routing_weights,
    const at::Tensor& selected_experts,
    const at::Tensor& expert_usage) {
  validate_moe_dispatch_inputs(hidden_states, routing_weights, selected_experts, expert_usage);
  const auto total_routes = routing_weights.numel();
  auto index_options = selected_experts.options().device(c10::Device(c10::DeviceType::Meta)).dtype(at::kLong);
  auto hidden_options = hidden_states.options().device(c10::Device(c10::DeviceType::Meta));
  return {
      at::empty({total_routes}, index_options),
      at::empty({expert_usage.size(0) + 1}, index_options),
      at::empty({total_routes, hidden_states.size(1)}, hidden_options),
      at::empty({total_routes, 1}, hidden_options),
  };
}

at::Tensor moe_scatter_fused_meta(
    const at::Tensor& compact_outputs,
    const at::Tensor& sorted_token_idx,
    int64_t num_tokens) {
  validate_moe_scatter_inputs(compact_outputs, sorted_token_idx, num_tokens);
  auto meta_options = compact_outputs.options().device(c10::Device(c10::DeviceType::Meta));
  return at::empty({num_tokens, compact_outputs.size(1)}, meta_options);
}

std::tuple<at::Tensor, at::Tensor, at::Tensor, at::Tensor> moe_dispatch_fused_xpu(
    const at::Tensor& hidden_states_in,
    const at::Tensor& routing_weights_in,
    const at::Tensor& selected_experts_in,
    const at::Tensor& expert_usage_in) {
  validate_moe_dispatch_inputs(hidden_states_in, routing_weights_in, selected_experts_in, expert_usage_in);
  validate_moe_dispatch_xpu_inputs(hidden_states_in, routing_weights_in, selected_experts_in, expert_usage_in);

  auto hidden_states = hidden_states_in.contiguous();
  auto routing_weights = routing_weights_in.contiguous();
  auto selected_experts = selected_experts_in.contiguous();
  auto expert_usage = expert_usage_in.contiguous();

  const auto tokens = hidden_states.size(0);
  const auto hidden_dim = hidden_states.size(1);
  const auto top_k = routing_weights.size(1);
  const auto num_experts = expert_usage.size(0);
  const auto total_routes = tokens * top_k;
  const int64_t local_size =
      std::min<int64_t>(next_power_of_two(std::max<int64_t>(1, std::min<int64_t>(hidden_dim, 256))), 256);

  auto index_options = selected_experts.options().dtype(at::kLong);
  auto sorted_token_idx = at::empty({total_routes}, index_options);
  auto expert_offsets = at::empty({num_experts + 1}, index_options);
  auto route_counters = at::zeros({num_experts}, index_options);
  auto compact_hidden_states = at::empty({total_routes, hidden_dim}, hidden_states.options());
  auto compact_routing_weights = at::empty({total_routes, 1}, hidden_states.options());
  auto stream = c10::xpu::getCurrentXPUStream(hidden_states.device().index());

  AT_DISPATCH_INTEGRAL_TYPES(
      expert_usage.scalar_type(),
      "moe_dispatch_offsets_xpu",
      [&] {
        const scalar_t* usage_ptr = expert_usage.const_data_ptr<scalar_t>();
        int64_t* offsets_ptr = expert_offsets.mutable_data_ptr<int64_t>();
        stream.queue().submit([&](sycl::handler& cgh) {
          cgh.single_task([=]() {
            int64_t running_offset = 0;
            offsets_ptr[0] = 0;
            for (int64_t expert_idx = 0; expert_idx < num_experts; ++expert_idx) {
              running_offset += static_cast<int64_t>(usage_ptr[expert_idx]);
              offsets_ptr[expert_idx + 1] = running_offset;
            }
          });
        });
      });

  AT_DISPATCH_FLOATING_TYPES_AND2(
      at::kHalf,
      at::kBFloat16,
      hidden_states.scalar_type(),
      "moe_dispatch_fused_xpu",
      [&] {
        const scalar_t* hidden_ptr = hidden_states.const_data_ptr<scalar_t>();
        const scalar_t* routing_ptr = routing_weights.const_data_ptr<scalar_t>();
        const int64_t* selected_ptr = selected_experts.const_data_ptr<int64_t>();
        const int64_t* offsets_ptr = expert_offsets.const_data_ptr<int64_t>();
        int64_t* counters_ptr = route_counters.mutable_data_ptr<int64_t>();
        int64_t* sorted_token_ptr = sorted_token_idx.mutable_data_ptr<int64_t>();
        scalar_t* compact_hidden_ptr = compact_hidden_states.mutable_data_ptr<scalar_t>();
        scalar_t* compact_weight_ptr = compact_routing_weights.mutable_data_ptr<scalar_t>();
        const size_t route_count = static_cast<size_t>(total_routes);

        stream.queue().submit([&](sycl::handler& cgh) {
          sycl::local_accessor<int64_t, 1> route_position(sycl::range<1>(1), cgh);
          cgh.parallel_for(
              sycl::nd_range<2>(
                  sycl::range<2>(route_count, static_cast<size_t>(local_size)),
                  sycl::range<2>(1, static_cast<size_t>(local_size))),
              [=](sycl::nd_item<2> item) {
                const int64_t route_linear = static_cast<int64_t>(item.get_group(0));
                const int64_t lane = static_cast<int64_t>(item.get_local_id(1));
                const int64_t token_idx = route_linear / top_k;
                const int64_t route_idx = route_linear - token_idx * top_k;
                const int64_t expert_idx = selected_ptr[route_linear];

                if (lane == 0) {
                  auto counter_ref = sycl::atomic_ref<
                      int64_t,
                      sycl::memory_order::relaxed,
                      sycl::memory_scope::device,
                      sycl::access::address_space::global_space>(counters_ptr[expert_idx]);
                  route_position[0] = offsets_ptr[expert_idx] + counter_ref.fetch_add(1);
                  sorted_token_ptr[route_position[0]] = token_idx;
                  compact_weight_ptr[route_position[0]] = routing_ptr[token_idx * top_k + route_idx];
                }
                item.barrier(sycl::access::fence_space::local_space);

                const int64_t output_base = route_position[0] * hidden_dim;
                const int64_t input_base = token_idx * hidden_dim;
                for (int64_t dim_idx = lane; dim_idx < hidden_dim; dim_idx += local_size) {
                  compact_hidden_ptr[output_base + dim_idx] = hidden_ptr[input_base + dim_idx];
                }
              });
        });
      });

  return {sorted_token_idx, expert_offsets, compact_hidden_states, compact_routing_weights};
}

at::Tensor moe_scatter_fused_xpu(
    const at::Tensor& compact_outputs_in,
    const at::Tensor& sorted_token_idx_in,
    int64_t num_tokens) {
  validate_moe_scatter_inputs(compact_outputs_in, sorted_token_idx_in, num_tokens);
  validate_moe_scatter_xpu_inputs(compact_outputs_in, sorted_token_idx_in);

  auto compact_outputs = compact_outputs_in.contiguous();
  auto sorted_token_idx = sorted_token_idx_in.contiguous();
  const auto routes = compact_outputs.size(0);
  const auto hidden_dim = compact_outputs.size(1);
  const int64_t local_size =
      std::min<int64_t>(next_power_of_two(std::max<int64_t>(1, std::min<int64_t>(hidden_dim, 256))), 256);

  auto accum = at::zeros({num_tokens, hidden_dim}, compact_outputs.options().dtype(at::kFloat));
  auto output = at::empty({num_tokens, hidden_dim}, compact_outputs.options());
  auto stream = c10::xpu::getCurrentXPUStream(compact_outputs.device().index());

  AT_DISPATCH_FLOATING_TYPES_AND2(
      at::kHalf,
      at::kBFloat16,
      compact_outputs.scalar_type(),
      "moe_scatter_fused_xpu",
      [&] {
        const scalar_t* compact_ptr = compact_outputs.const_data_ptr<scalar_t>();
        const int64_t* token_ptr = sorted_token_idx.const_data_ptr<int64_t>();
        float* accum_ptr = accum.mutable_data_ptr<float>();
        scalar_t* output_ptr = output.mutable_data_ptr<scalar_t>();
        const size_t route_count = static_cast<size_t>(routes);
        const size_t output_rows = static_cast<size_t>(num_tokens);

        stream.queue().submit([&](sycl::handler& cgh) {
          cgh.parallel_for(
              sycl::nd_range<2>(
                  sycl::range<2>(route_count, static_cast<size_t>(local_size)),
                  sycl::range<2>(1, static_cast<size_t>(local_size))),
              [=](sycl::nd_item<2> item) {
                const int64_t route_idx = static_cast<int64_t>(item.get_group(0));
                const int64_t lane = static_cast<int64_t>(item.get_local_id(1));
                const int64_t token_idx = token_ptr[route_idx];
                const int64_t input_base = route_idx * hidden_dim;
                const int64_t output_base = token_idx * hidden_dim;
                for (int64_t dim_idx = lane; dim_idx < hidden_dim; dim_idx += local_size) {
                  auto output_ref = sycl::atomic_ref<
                      float,
                      sycl::memory_order::relaxed,
                      sycl::memory_scope::device,
                      sycl::access::address_space::global_space>(accum_ptr[output_base + dim_idx]);
                  output_ref.fetch_add(load_as_float(compact_ptr, input_base + dim_idx));
                }
              });
        });

        stream.queue().submit([&](sycl::handler& cgh) {
          cgh.parallel_for(
              sycl::nd_range<2>(
                  sycl::range<2>(output_rows, static_cast<size_t>(local_size)),
                  sycl::range<2>(1, static_cast<size_t>(local_size))),
              [=](sycl::nd_item<2> item) {
                const int64_t token_idx = static_cast<int64_t>(item.get_group(0));
                const int64_t lane = static_cast<int64_t>(item.get_local_id(1));
                const int64_t row_base = token_idx * hidden_dim;
                for (int64_t dim_idx = lane; dim_idx < hidden_dim; dim_idx += local_size) {
                  output_ptr[row_base + dim_idx] = static_cast<scalar_t>(accum_ptr[row_base + dim_idx]);
                }
              });
        });
      });

  return output;
}

at::Tensor moe_grouped_int4_mlp_fused_meta(
    const at::Tensor& compact_hidden_states,
    const at::Tensor& compact_routing_weights,
    const at::Tensor& compact_outputs,
    const at::Tensor& expert_offsets,
    const at::Tensor& active_experts,
    const at::Tensor& active_slots,
    const at::Tensor& gate_qweight,
    const at::Tensor& gate_qscale,
    const at::Tensor& gate_qzeros,
    const at::Tensor& up_qweight,
    const at::Tensor& up_qscale,
    const at::Tensor& up_qzeros,
    const at::Tensor& down_qweight,
    const at::Tensor& down_qscale,
    const at::Tensor& down_qzeros,
    int64_t group_size,
    int64_t max_routes_per_expert) {
  validate_moe_grouped_int4_mlp_inputs(
      compact_hidden_states,
      compact_routing_weights,
      compact_outputs,
      expert_offsets,
      active_experts,
      active_slots,
      gate_qweight,
      gate_qscale,
      gate_qzeros,
      up_qweight,
      up_qscale,
      up_qzeros,
      down_qweight,
      down_qscale,
      down_qzeros,
      group_size,
      max_routes_per_expert);
  return compact_outputs;
}

at::Tensor moe_grouped_int4_mlp_fused_xpu(
    const at::Tensor& compact_hidden_states_in,
    const at::Tensor& compact_routing_weights_in,
    const at::Tensor& compact_outputs_in,
    const at::Tensor& expert_offsets_in,
    const at::Tensor& active_experts_in,
    const at::Tensor& active_slots_in,
    const at::Tensor& gate_qweight_in,
    const at::Tensor& gate_qscale_in,
    const at::Tensor& gate_qzeros_in,
    const at::Tensor& up_qweight_in,
    const at::Tensor& up_qscale_in,
    const at::Tensor& up_qzeros_in,
    const at::Tensor& down_qweight_in,
    const at::Tensor& down_qscale_in,
    const at::Tensor& down_qzeros_in,
    int64_t group_size,
    int64_t max_routes_per_expert) {
  validate_moe_grouped_int4_mlp_inputs(
      compact_hidden_states_in,
      compact_routing_weights_in,
      compact_outputs_in,
      expert_offsets_in,
      active_experts_in,
      active_slots_in,
      gate_qweight_in,
      gate_qscale_in,
      gate_qzeros_in,
      up_qweight_in,
      up_qscale_in,
      up_qzeros_in,
      down_qweight_in,
      down_qscale_in,
      down_qzeros_in,
      group_size,
      max_routes_per_expert);
  validate_moe_grouped_int4_mlp_xpu_inputs(
      compact_hidden_states_in,
      compact_routing_weights_in,
      compact_outputs_in,
      expert_offsets_in,
      active_experts_in,
      active_slots_in,
      gate_qweight_in,
      gate_qscale_in,
      gate_qzeros_in,
      up_qweight_in,
      up_qscale_in,
      up_qzeros_in,
      down_qweight_in,
      down_qscale_in,
      down_qzeros_in);

  auto compact_hidden_states = compact_hidden_states_in.contiguous();
  auto compact_routing_weights = compact_routing_weights_in.contiguous();
  auto output = compact_outputs_in;
  auto expert_offsets = expert_offsets_in.contiguous();
  auto active_experts = active_experts_in.contiguous();
  auto active_slots = active_slots_in.contiguous();
  auto gate_qweight = gate_qweight_in.contiguous();
  auto gate_qscale = gate_qscale_in.contiguous();
  auto gate_qzeros = gate_qzeros_in.contiguous();
  auto up_qweight = up_qweight_in.contiguous();
  auto up_qscale = up_qscale_in.contiguous();
  auto up_qzeros = up_qzeros_in.contiguous();
  auto down_qweight = down_qweight_in.contiguous();
  auto down_qscale = down_qscale_in.contiguous();
  auto down_qzeros = down_qzeros_in.contiguous();

  const auto routes = compact_hidden_states.size(0);
  const auto hidden_dim = compact_hidden_states.size(1);
  const auto active_count = active_experts.size(0);
  const auto intermediate_dim = gate_qweight.size(1);
  const auto hidden_packed_cols = gate_qweight.size(2);
  const auto hidden_group_count = gate_qscale.size(1);
  const auto intermediate_packed_cols = down_qweight.size(2);
  const auto intermediate_group_count = down_qscale.size(1);

  if (routes == 0) {
    return output;
  }

  auto activation = at::empty({routes, intermediate_dim}, compact_hidden_states.options().dtype(at::kFloat));
  auto stream = c10::xpu::getCurrentXPUStream(compact_hidden_states.device().index());
  const int64_t gate_local_size =
      std::min<int64_t>(next_power_of_two(std::max<int64_t>(1, std::min<int64_t>(hidden_dim, 256))), 256);
  const int64_t down_local_size =
      std::min<int64_t>(next_power_of_two(std::max<int64_t>(1, std::min<int64_t>(intermediate_dim, 256))), 256);
  const size_t active_range = static_cast<size_t>(active_count);
  const size_t gate_group_range = static_cast<size_t>(max_routes_per_expert * intermediate_dim);
  const size_t down_group_range = static_cast<size_t>(max_routes_per_expert * hidden_dim);

  AT_DISPATCH_FLOATING_TYPES_AND2(
      at::kHalf,
      at::kBFloat16,
      compact_hidden_states.scalar_type(),
      "moe_grouped_int4_mlp_gate_up_xpu",
      [&] {
        const scalar_t* hidden_ptr = compact_hidden_states.const_data_ptr<scalar_t>();
        const scalar_t* routing_ptr = compact_routing_weights.const_data_ptr<scalar_t>();
        (void)routing_ptr;
        const int64_t* offsets_ptr = expert_offsets.const_data_ptr<int64_t>();
        const int64_t* active_experts_ptr = active_experts.const_data_ptr<int64_t>();
        const int64_t* active_slots_ptr = active_slots.const_data_ptr<int64_t>();
        const int32_t* gate_qweight_ptr = gate_qweight.const_data_ptr<int32_t>();
        const float* gate_qscale_ptr = gate_qscale.const_data_ptr<float>();
        const int8_t* gate_qzeros_ptr = gate_qzeros.const_data_ptr<int8_t>();
        const int32_t* up_qweight_ptr = up_qweight.const_data_ptr<int32_t>();
        const float* up_qscale_ptr = up_qscale.const_data_ptr<float>();
        const int8_t* up_qzeros_ptr = up_qzeros.const_data_ptr<int8_t>();
        float* activation_ptr = activation.mutable_data_ptr<float>();

        stream.queue().submit([&](sycl::handler& cgh) {
          sycl::local_accessor<float, 1> partial_gate(sycl::range<1>(static_cast<size_t>(gate_local_size)), cgh);
          sycl::local_accessor<float, 1> partial_up(sycl::range<1>(static_cast<size_t>(gate_local_size)), cgh);
          cgh.parallel_for(
              sycl::nd_range<2>(
                  sycl::range<2>(active_range, gate_group_range * static_cast<size_t>(gate_local_size)),
                  sycl::range<2>(1, static_cast<size_t>(gate_local_size))),
              [=](sycl::nd_item<2> item) {
                const int64_t active_idx = static_cast<int64_t>(item.get_group(0));
                const int64_t linear_idx = static_cast<int64_t>(item.get_group(1));
                const int64_t lane = static_cast<int64_t>(item.get_local_id(1));
                const int64_t expert_idx = active_experts_ptr[active_idx];
                const int64_t bank_slot = active_slots_ptr[active_idx];
                const int64_t start = offsets_ptr[expert_idx];
                const int64_t end = offsets_ptr[expert_idx + 1];
                const int64_t route_count = end - start;
                const int64_t route_offset = linear_idx / intermediate_dim;
                const int64_t intermediate_idx = linear_idx - route_offset * intermediate_dim;
                if (route_offset >= route_count) {
                  return;
                }

                const int64_t route_idx = start + route_offset;
                const int64_t hidden_base = route_idx * hidden_dim;
                float gate_acc = 0.0f;
                float up_acc = 0.0f;
                for (int64_t hidden_idx = lane; hidden_idx < hidden_dim; hidden_idx += gate_local_size) {
                  const float hidden_value = load_as_float(hidden_ptr, hidden_base + hidden_idx);
                  gate_acc += hidden_value *
                      load_grouped_int4_weight(
                          gate_qweight_ptr,
                          gate_qscale_ptr,
                          gate_qzeros_ptr,
                          bank_slot,
                          intermediate_idx,
                          hidden_idx,
                          intermediate_dim,
                          hidden_packed_cols,
                          hidden_group_count,
                          group_size);
                  up_acc += hidden_value *
                      load_grouped_int4_weight(
                          up_qweight_ptr,
                          up_qscale_ptr,
                          up_qzeros_ptr,
                          bank_slot,
                          intermediate_idx,
                          hidden_idx,
                          intermediate_dim,
                          hidden_packed_cols,
                          hidden_group_count,
                          group_size);
                }

                partial_gate[lane] = gate_acc;
                partial_up[lane] = up_acc;
                item.barrier(sycl::access::fence_space::local_space);
                for (int64_t stride = gate_local_size / 2; stride > 0; stride >>= 1) {
                  if (lane < stride) {
                    partial_gate[lane] += partial_gate[lane + stride];
                    partial_up[lane] += partial_up[lane + stride];
                  }
                  item.barrier(sycl::access::fence_space::local_space);
                }
                if (lane == 0) {
                  const float gate_value = partial_gate[0];
                  const float silu_gate = gate_value / (1.0f + sycl::exp(-gate_value));
                  activation_ptr[route_idx * intermediate_dim + intermediate_idx] = silu_gate * partial_up[0];
                }
              });
        });
      });

  AT_DISPATCH_FLOATING_TYPES_AND2(
      at::kHalf,
      at::kBFloat16,
      compact_hidden_states.scalar_type(),
      "moe_grouped_int4_mlp_down_xpu",
      [&] {
        const scalar_t* routing_ptr = compact_routing_weights.const_data_ptr<scalar_t>();
        const int64_t* offsets_ptr = expert_offsets.const_data_ptr<int64_t>();
        const int64_t* active_experts_ptr = active_experts.const_data_ptr<int64_t>();
        const int64_t* active_slots_ptr = active_slots.const_data_ptr<int64_t>();
        const float* activation_ptr = activation.const_data_ptr<float>();
        const int32_t* down_qweight_ptr = down_qweight.const_data_ptr<int32_t>();
        const float* down_qscale_ptr = down_qscale.const_data_ptr<float>();
        const int8_t* down_qzeros_ptr = down_qzeros.const_data_ptr<int8_t>();
        scalar_t* output_ptr = output.mutable_data_ptr<scalar_t>();

        stream.queue().submit([&](sycl::handler& cgh) {
          sycl::local_accessor<float, 1> partial_down(sycl::range<1>(static_cast<size_t>(down_local_size)), cgh);
          cgh.parallel_for(
              sycl::nd_range<2>(
                  sycl::range<2>(active_range, down_group_range * static_cast<size_t>(down_local_size)),
                  sycl::range<2>(1, static_cast<size_t>(down_local_size))),
              [=](sycl::nd_item<2> item) {
                const int64_t active_idx = static_cast<int64_t>(item.get_group(0));
                const int64_t linear_idx = static_cast<int64_t>(item.get_group(1));
                const int64_t lane = static_cast<int64_t>(item.get_local_id(1));
                const int64_t expert_idx = active_experts_ptr[active_idx];
                const int64_t bank_slot = active_slots_ptr[active_idx];
                const int64_t start = offsets_ptr[expert_idx];
                const int64_t end = offsets_ptr[expert_idx + 1];
                const int64_t route_count = end - start;
                const int64_t route_offset = linear_idx / hidden_dim;
                const int64_t hidden_idx = linear_idx - route_offset * hidden_dim;
                if (route_offset >= route_count) {
                  return;
                }

                const int64_t route_idx = start + route_offset;
                const int64_t activation_base = route_idx * intermediate_dim;
                float down_acc = 0.0f;
                for (int64_t intermediate_idx = lane; intermediate_idx < intermediate_dim; intermediate_idx += down_local_size) {
                  down_acc += activation_ptr[activation_base + intermediate_idx] *
                      load_grouped_int4_weight(
                          down_qweight_ptr,
                          down_qscale_ptr,
                          down_qzeros_ptr,
                          bank_slot,
                          hidden_idx,
                          intermediate_idx,
                          hidden_dim,
                          intermediate_packed_cols,
                          intermediate_group_count,
                          group_size);
                }

                partial_down[lane] = down_acc;
                item.barrier(sycl::access::fence_space::local_space);
                for (int64_t stride = down_local_size / 2; stride > 0; stride >>= 1) {
                  if (lane < stride) {
                    partial_down[lane] += partial_down[lane + stride];
                  }
                  item.barrier(sycl::access::fence_space::local_space);
                }
                if (lane == 0) {
                  const float route_weight = load_as_float(routing_ptr, route_idx);
                  output_ptr[route_idx * hidden_dim + hidden_idx] =
                      static_cast<scalar_t>(partial_down[0] * route_weight);
                }
              });
        });
      });

  return output;
}

at::Tensor gqa_decode_fused_meta(
    const at::Tensor& query,
    const at::Tensor& key,
    const at::Tensor& value,
    const at::Tensor& visible_lengths,
    double /*scaling*/,
    const c10::optional<at::Tensor>& gate_opt) {
  validate_gqa_decode_inputs(query, key, value, visible_lengths);
  validate_gqa_decode_optional_gate(query, gate_opt);
  auto meta_options = query.options().device(c10::Device(c10::DeviceType::Meta));
  return at::empty(query.sizes(), meta_options);
}

at::Tensor gqa_decode_fused_xpu(
    const at::Tensor& query_in,
    const at::Tensor& key_in,
    const at::Tensor& value_in,
    const at::Tensor& visible_lengths_in,
    double scaling,
    const c10::optional<at::Tensor>& gate_opt) {
  validate_gqa_decode_inputs(query_in, key_in, value_in, visible_lengths_in);
  validate_gqa_decode_optional_gate(query_in, gate_opt);
  validate_gqa_decode_xpu_inputs(query_in, key_in, value_in, visible_lengths_in);

  auto query = query_in.contiguous();
  auto key = key_in.contiguous();
  auto value = value_in.contiguous();
  auto visible_lengths = visible_lengths_in.contiguous();
  c10::optional<at::Tensor> gate_contig = c10::nullopt;
  if (gate_opt.has_value() && gate_opt->defined()) {
    TORCH_CHECK(
        gate_opt->device() == query.device(),
        "gate must be on the same XPU device as query");
    gate_contig = gate_opt->contiguous();
  }
  auto output = at::empty(query.sizes(), query.options());

  const auto batch_size = query.size(0);
  const auto num_heads = query.size(1);
  const auto num_kv_heads = key.size(1);
  const auto key_len = key.size(2);
  const auto head_dim = query.size(3);
  const auto groups_per_kv_head = num_heads / num_kv_heads;
  const int64_t local_size =
      std::min<int64_t>(next_power_of_two(std::max<int64_t>(1, std::min<int64_t>(head_dim, 128))), 128);
  constexpr int64_t kMaxAccumSlots = 8;
  TORCH_CHECK(
      ((head_dim + local_size - 1) / local_size) <= kMaxAccumSlots,
      "gqa_decode_fused_xpu head_dim is too large for the current accumulator configuration");
  const float scaling_f = static_cast<float>(scaling);
  auto stream = c10::xpu::getCurrentXPUStream(query.device().index());

  // Dot-product reduction: one reduce_over_group over the 1×local_size work-group per (batch, head)
  // replaces local memory + log2(local_size) barriers per key position (online softmax loop).
  AT_DISPATCH_FLOATING_TYPES_AND2(
      at::kHalf,
      at::kBFloat16,
      query.scalar_type(),
      "gqa_decode_fused_xpu",
      [&] {
        const scalar_t* query_ptr = query.const_data_ptr<scalar_t>();
        const scalar_t* key_ptr = key.const_data_ptr<scalar_t>();
        const scalar_t* value_ptr = value.const_data_ptr<scalar_t>();
        const int64_t* visible_lengths_ptr = visible_lengths.const_data_ptr<int64_t>();
        scalar_t* output_ptr = output.mutable_data_ptr<scalar_t>();
        const scalar_t* gate_ptr =
            (gate_contig.has_value() && gate_contig->defined()) ? gate_contig->const_data_ptr<scalar_t>() : nullptr;
        const size_t group_count = static_cast<size_t>(batch_size * num_heads);

        stream.queue().submit([&](sycl::handler& cgh) {
          cgh.parallel_for(
              sycl::nd_range<2>(
                  sycl::range<2>(group_count, static_cast<size_t>(local_size)),
                  sycl::range<2>(1, static_cast<size_t>(local_size))),
              [=](sycl::nd_item<2> item) {
                const int64_t bh = static_cast<int64_t>(item.get_group(0));
                const int64_t lane = static_cast<int64_t>(item.get_local_id(1));
                const int64_t batch_idx = bh / num_heads;
                const int64_t head_idx = bh % num_heads;
                const int64_t kv_head_idx = head_idx / groups_per_kv_head;
                const int64_t query_base = ((batch_idx * num_heads + head_idx) * head_dim);
                const int64_t key_base = ((batch_idx * num_kv_heads + kv_head_idx) * key_len) * head_dim;
                const int64_t output_base = query_base;

                int64_t visible_len = visible_lengths_ptr[batch_idx];
                visible_len = sycl::max<int64_t>(0, sycl::min<int64_t>(visible_len, key_len));
                float running_max = -std::numeric_limits<float>::infinity();
                float denom = 0.0f;
                float accumulators[kMaxAccumSlots];
                for (int64_t slot = 0; slot < kMaxAccumSlots; ++slot) {
                  accumulators[slot] = 0.0f;
                }

                for (int64_t key_idx = 0; key_idx < visible_len; ++key_idx) {
                  float local_dot = 0.0f;
                  for (int64_t dim_idx = lane; dim_idx < head_dim; dim_idx += local_size) {
                    local_dot +=
                        load_as_float(query_ptr, query_base + dim_idx) *
                        load_as_float(key_ptr, key_base + key_idx * head_dim + dim_idx);
                  }
                  const float dot_sum =
                      sycl::reduce_over_group(item.get_group(), local_dot, sycl::plus<float>());
                  const float score = dot_sum * scaling_f;
                  const float new_max = sycl::fmax(running_max, score);
                  const float old_scale = denom == 0.0f ? 0.0f : sycl::exp(running_max - new_max);
                  const float score_scale = sycl::exp(score - new_max);
                  int64_t slot = 0;
                  for (int64_t dim_idx = lane; dim_idx < head_dim; dim_idx += local_size, ++slot) {
                    accumulators[slot] =
                        accumulators[slot] * old_scale +
                        score_scale * load_as_float(value_ptr, key_base + key_idx * head_dim + dim_idx);
                  }
                  denom = denom * old_scale + score_scale;
                  running_max = new_max;
                }

                int64_t slot = 0;
                for (int64_t dim_idx = lane; dim_idx < head_dim; dim_idx += local_size, ++slot) {
                  float out_value = denom > 0.0f ? accumulators[slot] / denom : 0.0f;
                  if (gate_ptr != nullptr) {
                    const int64_t gate_off = (batch_idx * num_heads + head_idx) * head_dim + dim_idx;
                    const float gpre = load_as_float(gate_ptr, gate_off);
                    out_value *= (1.0f / (1.0f + sycl::exp(-gpre)));
                  }
                  output_ptr[output_base + dim_idx] = static_cast<scalar_t>(out_value);
                }
              });
        });
      });

  return output;
}

at::Tensor paged_gqa_decode_fused_meta(
    const at::Tensor& query,
    const at::Tensor& key_pages,
    const at::Tensor& value_pages,
    const at::Tensor& page_table,
    const at::Tensor& visible_lengths,
    double /*scaling*/,
    const c10::optional<at::Tensor>& gate_opt) {
  validate_paged_gqa_decode_inputs(query, key_pages, value_pages, page_table, visible_lengths);
  validate_gqa_decode_optional_gate(query, gate_opt);
  auto meta_options = query.options().device(c10::Device(c10::DeviceType::Meta));
  return at::empty(query.sizes(), meta_options);
}

at::Tensor paged_gqa_decode_fused_xpu(
    const at::Tensor& query_in,
    const at::Tensor& key_pages_in,
    const at::Tensor& value_pages_in,
    const at::Tensor& page_table_in,
    const at::Tensor& visible_lengths_in,
    double scaling,
    const c10::optional<at::Tensor>& gate_opt) {
  validate_paged_gqa_decode_inputs(query_in, key_pages_in, value_pages_in, page_table_in, visible_lengths_in);
  validate_gqa_decode_optional_gate(query_in, gate_opt);
  validate_paged_gqa_decode_xpu_inputs(query_in, key_pages_in, value_pages_in, page_table_in, visible_lengths_in);

  auto query = query_in.contiguous();
  auto key_pages = key_pages_in.contiguous();
  auto value_pages = value_pages_in.contiguous();
  auto page_table = page_table_in.contiguous();
  auto visible_lengths = visible_lengths_in.contiguous();
  c10::optional<at::Tensor> gate_contig = c10::nullopt;
  if (gate_opt.has_value() && gate_opt->defined()) {
    TORCH_CHECK(
        gate_opt->device() == query.device(),
        "gate must be on the same XPU device as query");
    gate_contig = gate_opt->contiguous();
  }
  auto output = at::empty(query.sizes(), query.options());

  const auto batch_size = query.size(0);
  const auto num_heads = query.size(1);
  const auto num_kv_heads = key_pages.size(1);
  const auto block_size = key_pages.size(2);
  const auto head_dim = query.size(3);
  const auto max_blocks = page_table.size(1);
  const auto max_visible_len = max_blocks * block_size;
  const auto total_pages = key_pages.size(0);
  const auto groups_per_kv_head = num_heads / num_kv_heads;
  const int64_t local_size =
      std::min<int64_t>(next_power_of_two(std::max<int64_t>(1, std::min<int64_t>(head_dim, 128))), 128);
  constexpr int64_t kMaxAccumSlots = 8;
  TORCH_CHECK(
      ((head_dim + local_size - 1) / local_size) <= kMaxAccumSlots,
      "paged_gqa_decode_fused_xpu head_dim is too large for the current accumulator configuration");
  const float scaling_f = static_cast<float>(scaling);
  auto stream = c10::xpu::getCurrentXPUStream(query.device().index());

  // Same reduction strategy as gqa_decode_fused_xpu (see comment there).
  AT_DISPATCH_FLOATING_TYPES_AND2(
      at::kHalf,
      at::kBFloat16,
      query.scalar_type(),
      "paged_gqa_decode_fused_xpu",
      [&] {
        const scalar_t* query_ptr = query.const_data_ptr<scalar_t>();
        const scalar_t* key_pages_ptr = key_pages.const_data_ptr<scalar_t>();
        const scalar_t* value_pages_ptr = value_pages.const_data_ptr<scalar_t>();
        const int32_t* page_table_ptr = page_table.const_data_ptr<int32_t>();
        const int64_t* visible_lengths_ptr = visible_lengths.const_data_ptr<int64_t>();
        scalar_t* output_ptr = output.mutable_data_ptr<scalar_t>();
        const scalar_t* gate_ptr =
            (gate_contig.has_value() && gate_contig->defined()) ? gate_contig->const_data_ptr<scalar_t>() : nullptr;
        const size_t group_count = static_cast<size_t>(batch_size * num_heads);

        stream.queue().submit([&](sycl::handler& cgh) {
          cgh.parallel_for(
              sycl::nd_range<2>(
                  sycl::range<2>(group_count, static_cast<size_t>(local_size)),
                  sycl::range<2>(1, static_cast<size_t>(local_size))),
              [=](sycl::nd_item<2> item) {
                const int64_t bh = static_cast<int64_t>(item.get_group(0));
                const int64_t lane = static_cast<int64_t>(item.get_local_id(1));
                const int64_t batch_idx = bh / num_heads;
                const int64_t head_idx = bh % num_heads;
                const int64_t kv_head_idx = head_idx / groups_per_kv_head;
                const int64_t query_base = ((batch_idx * num_heads + head_idx) * head_dim);
                const int64_t output_base = query_base;

                int64_t visible_len = visible_lengths_ptr[batch_idx];
                visible_len = sycl::max<int64_t>(0, sycl::min<int64_t>(visible_len, max_visible_len));
                float running_max = -std::numeric_limits<float>::infinity();
                float denom = 0.0f;
                float accumulators[kMaxAccumSlots];
                for (int64_t slot = 0; slot < kMaxAccumSlots; ++slot) {
                  accumulators[slot] = 0.0f;
                }

                for (int64_t key_idx = 0; key_idx < visible_len; ++key_idx) {
                  const int64_t block_idx = key_idx / block_size;
                  const int64_t block_offset = key_idx % block_size;
                  const int32_t page_id = page_table_ptr[batch_idx * max_blocks + block_idx];
                  if (page_id < 0 || page_id >= total_pages) {
                    continue;
                  }

                  const int64_t page_base =
                      (((static_cast<int64_t>(page_id) * num_kv_heads) + kv_head_idx) * block_size + block_offset) *
                      head_dim;
                  float local_dot = 0.0f;
                  for (int64_t dim_idx = lane; dim_idx < head_dim; dim_idx += local_size) {
                    local_dot +=
                        load_as_float(query_ptr, query_base + dim_idx) *
                        load_as_float(key_pages_ptr, page_base + dim_idx);
                  }
                  const float dot_sum =
                      sycl::reduce_over_group(item.get_group(), local_dot, sycl::plus<float>());
                  const float score = dot_sum * scaling_f;
                  const float new_max = sycl::fmax(running_max, score);
                  const float old_scale = denom == 0.0f ? 0.0f : sycl::exp(running_max - new_max);
                  const float score_scale = sycl::exp(score - new_max);
                  int64_t slot = 0;
                  for (int64_t dim_idx = lane; dim_idx < head_dim; dim_idx += local_size, ++slot) {
                    accumulators[slot] =
                        accumulators[slot] * old_scale +
                        score_scale * load_as_float(value_pages_ptr, page_base + dim_idx);
                  }
                  denom = denom * old_scale + score_scale;
                  running_max = new_max;
                }

                int64_t slot = 0;
                for (int64_t dim_idx = lane; dim_idx < head_dim; dim_idx += local_size, ++slot) {
                  float out_value = denom > 0.0f ? accumulators[slot] / denom : 0.0f;
                  if (gate_ptr != nullptr) {
                    const int64_t gate_off = (batch_idx * num_heads + head_idx) * head_dim + dim_idx;
                    const float gpre = load_as_float(gate_ptr, gate_off);
                    out_value *= (1.0f / (1.0f + sycl::exp(-gpre)));
                  }
                  output_ptr[output_base + dim_idx] = static_cast<scalar_t>(out_value);
                }
              });
        });
      });

  return output;
}

std::tuple<at::Tensor, at::Tensor> gated_delta_prefill_meta(
    const at::Tensor& query_in,
    const at::Tensor& key_in,
    const at::Tensor& value_in,
    const at::Tensor& g_in,
    const at::Tensor& beta_in,
    const at::Tensor& state_in) {
  validate_gated_delta_inputs(query_in, key_in, value_in, g_in, beta_in, state_in);
  TORCH_CHECK(query_in.size(1) > 1, "gated_delta_prefill expects seq_len > 1");
  auto meta_options = query_in.options().device(c10::Device(c10::DeviceType::Meta));
  auto output = at::empty(
      {query_in.size(0), query_in.size(1), query_in.size(2), value_in.size(3)},
      meta_options);
  auto final_state = at::empty(state_in.sizes(), meta_options.dtype(at::kFloat));
  return {output, final_state};
}

at::Tensor gated_delta_decode_meta(
    const at::Tensor& query_in,
    const at::Tensor& key_in,
    const at::Tensor& value_in,
    const at::Tensor& g_in,
    const at::Tensor& beta_in,
    const at::Tensor& state_in) {
  validate_gated_delta_inputs(query_in, key_in, value_in, g_in, beta_in, state_in);
  TORCH_CHECK(query_in.size(1) == 1, "gated_delta_decode expects seq_len == 1");
  auto meta_options = query_in.options().device(c10::Device(c10::DeviceType::Meta));
  auto output = at::empty(
      {query_in.size(0), query_in.size(1), query_in.size(2), value_in.size(3)},
      meta_options);
  return output;
}

template <typename scalar_t>
void launch_gated_delta_prefill_kernel(
    sycl::queue& queue,
    const scalar_t* query_ptr,
    const scalar_t* key_ptr,
    const scalar_t* value_ptr,
    const float* g_ptr,
    const float* beta_ptr,
    const float* state_read_ptr,
    float* state_write_ptr,
    scalar_t* output_ptr,
    int64_t batch_size,
    int64_t sequence_length,
    int64_t num_heads,
    int64_t key_head_dim,
    int64_t value_head_dim,
    int64_t local_size,
    float l2_eps_f,
    float query_scale_base) {
  const size_t group_count = static_cast<size_t>(batch_size * num_heads);
  queue.submit([&](sycl::handler& cgh) {
    sycl::local_accessor<float, 1> partial_sum(sycl::range<1>(static_cast<size_t>(local_size)), cgh);
    sycl::local_accessor<float, 1> partial_sum_aux(sycl::range<1>(static_cast<size_t>(local_size)), cgh);
    sycl::local_accessor<float, 1> normalized_query(sycl::range<1>(static_cast<size_t>(key_head_dim)), cgh);
    sycl::local_accessor<float, 1> normalized_key(sycl::range<1>(static_cast<size_t>(key_head_dim)), cgh);
    cgh.parallel_for(
        sycl::nd_range<2>(
            sycl::range<2>(group_count, static_cast<size_t>(local_size)),
            sycl::range<2>(1, static_cast<size_t>(local_size))),
        [=](sycl::nd_item<2> item) {
          const int64_t bh = static_cast<int64_t>(item.get_group(0));
          const int64_t lane = static_cast<int64_t>(item.get_local_id(1));
          const int64_t b = bh / num_heads;
          const int64_t h = bh % num_heads;
          const int64_t state_base = ((b * num_heads) + h) * key_head_dim * value_head_dim;

          for (int64_t t = 0; t < sequence_length; ++t) {
            const int64_t scalar_index = ((b * sequence_length + t) * num_heads) + h;
            const float g_scale = sycl::exp(g_ptr[scalar_index]);
            const float beta_value = beta_ptr[scalar_index];
            const int64_t q_t_base = scalar_index * key_head_dim;
            const int64_t k_t_base = scalar_index * key_head_dim;
            const int64_t v_t_base = scalar_index * value_head_dim;

            normalize_gated_delta_qk(
                query_ptr,
                key_ptr,
                q_t_base,
                k_t_base,
                key_head_dim,
                local_size,
                l2_eps_f,
                query_scale_base,
                item,
                partial_sum,
                partial_sum_aux,
                normalized_query,
                normalized_key);

            const float* state_source_ptr = t == 0 ? state_read_ptr : state_write_ptr;
            for (int64_t v_idx = lane; v_idx < value_head_dim; v_idx += local_size) {
              const float kv_mem = gated_delta_decay_state_and_compute_kv_mem(
                  state_source_ptr,
                  state_write_ptr,
                  state_base,
                  value_head_dim,
                  key_head_dim,
                  v_idx,
                  g_scale,
                  normalized_key);
              const float delta = gated_delta_compute_delta(value_ptr, v_t_base, v_idx, kv_mem, beta_value);
              gated_delta_apply_delta_update(
                  state_write_ptr,
                  state_base,
                  value_head_dim,
                  key_head_dim,
                  v_idx,
                  delta,
                  normalized_key);
              const float out_value = gated_delta_accumulate_output(
                  state_write_ptr,
                  state_base,
                  value_head_dim,
                  key_head_dim,
                  v_idx,
                  normalized_query);
              const int64_t out_index = (((b * sequence_length + t) * num_heads) + h) * value_head_dim + v_idx;
              gated_delta_store_output(output_ptr, out_index, out_value);
            }
            item.barrier(sycl::access::fence_space::local_space);
          }
        });
  });
}

template <typename scalar_t>
void launch_gated_delta_decode_kernel(
    sycl::queue& queue,
    const scalar_t* query_ptr,
    const scalar_t* key_ptr,
    const scalar_t* value_ptr,
    const float* g_ptr,
    const float* beta_ptr,
    const float* state_read_ptr,
    float* state_write_ptr,
    scalar_t* output_ptr,
    int64_t batch_size,
    int64_t num_heads,
    int64_t key_head_dim,
    int64_t value_head_dim,
    int64_t local_size,
    float l2_eps_f,
    float query_scale_base) {
  const size_t group_count = static_cast<size_t>(batch_size * num_heads);
  queue.submit([&](sycl::handler& cgh) {
    sycl::local_accessor<float, 1> partial_sum(sycl::range<1>(static_cast<size_t>(local_size)), cgh);
    sycl::local_accessor<float, 1> partial_sum_aux(sycl::range<1>(static_cast<size_t>(local_size)), cgh);
    sycl::local_accessor<float, 1> normalized_query(sycl::range<1>(static_cast<size_t>(key_head_dim)), cgh);
    sycl::local_accessor<float, 1> normalized_key(sycl::range<1>(static_cast<size_t>(key_head_dim)), cgh);
    cgh.parallel_for(
        sycl::nd_range<2>(
            sycl::range<2>(group_count, static_cast<size_t>(local_size)),
            sycl::range<2>(1, static_cast<size_t>(local_size))),
        [=](sycl::nd_item<2> item) {
          const int64_t bh = static_cast<int64_t>(item.get_group(0));
          const int64_t lane = static_cast<int64_t>(item.get_local_id(1));
          const int64_t b = bh / num_heads;
          const int64_t h = bh % num_heads;
          const int64_t scalar_index = (b * num_heads) + h;
          const int64_t state_base = ((b * num_heads) + h) * key_head_dim * value_head_dim;
          const int64_t q_t_base = scalar_index * key_head_dim;
          const int64_t k_t_base = scalar_index * key_head_dim;
          const int64_t v_t_base = scalar_index * value_head_dim;

          normalize_gated_delta_qk(
              query_ptr,
              key_ptr,
              q_t_base,
              k_t_base,
              key_head_dim,
              local_size,
              l2_eps_f,
              query_scale_base,
              item,
              partial_sum,
              partial_sum_aux,
              normalized_query,
              normalized_key);

          const float g_scale = sycl::exp(g_ptr[scalar_index]);
          const float beta_value = beta_ptr[scalar_index];
          for (int64_t v_idx = lane; v_idx < value_head_dim; v_idx += local_size) {
            const float kv_mem = gated_delta_decay_state_and_compute_kv_mem(
                state_read_ptr,
                state_write_ptr,
                state_base,
                value_head_dim,
                key_head_dim,
                v_idx,
                g_scale,
                normalized_key);
            const float delta = gated_delta_compute_delta(value_ptr, v_t_base, v_idx, kv_mem, beta_value);
            gated_delta_apply_delta_update(
                state_write_ptr,
                state_base,
                value_head_dim,
                key_head_dim,
                v_idx,
                delta,
                normalized_key);
            const float out_value = gated_delta_accumulate_output(
                state_write_ptr,
                state_base,
                value_head_dim,
                key_head_dim,
                v_idx,
                normalized_query);
            const int64_t out_index = ((b * num_heads) + h) * value_head_dim + v_idx;
            gated_delta_store_output(output_ptr, out_index, out_value);
          }
          item.barrier(sycl::access::fence_space::local_space);
        });
  });
}

std::tuple<at::Tensor, at::Tensor> gated_delta_prefill_xpu(
    const at::Tensor& query_in,
    const at::Tensor& key_in,
    const at::Tensor& value_in,
    const at::Tensor& g_in,
    const at::Tensor& beta_in,
    const at::Tensor& state_in) {
  validate_gated_delta_inputs(query_in, key_in, value_in, g_in, beta_in, state_in);
  validate_gated_delta_xpu_inputs(query_in, key_in, value_in, g_in, beta_in, state_in);
  TORCH_CHECK(query_in.size(1) > 1, "gated_delta_prefill expects seq_len > 1");
  const auto initial_dtype = query_in.scalar_type();
  const auto batch_size = query_in.size(0);
  const auto sequence_length = query_in.size(1);
  const auto num_heads = query_in.size(2);
  const auto key_head_dim = query_in.size(3);
  const auto value_head_dim = value_in.size(3);
  auto output = at::empty(
      {batch_size, sequence_length, num_heads, value_head_dim},
      query_in.options());
  auto final_state = at::empty(state_in.sizes(), state_in.options());

  auto stream = c10::xpu::getCurrentXPUStream(query_in.device().index());
  const int64_t local_size = std::min<int64_t>(next_power_of_two(std::max<int64_t>(1, value_head_dim)), 256);
  validate_gated_delta_local_memory_requirements(stream.queue().get_device(), key_head_dim, local_size);

  const float* beta_ptr = beta_in.const_data_ptr<float>();
  const float* g_ptr = g_in.const_data_ptr<float>();
  const float* state_read_ptr = state_in.const_data_ptr<float>();
  float* state_write_ptr = final_state.mutable_data_ptr<float>();
  const float l2_eps_f = 1e-6f;
  const float query_scale_base = 1.0f / std::sqrt(static_cast<float>(key_head_dim));

  AT_DISPATCH_FLOATING_TYPES_AND2(
      at::kHalf,
      at::kBFloat16,
      initial_dtype,
      "gated_delta_prefill_xpu",
      [&] {
        const scalar_t* query_ptr = query_in.const_data_ptr<scalar_t>();
        const scalar_t* key_ptr = key_in.const_data_ptr<scalar_t>();
        const scalar_t* value_ptr = value_in.const_data_ptr<scalar_t>();
        scalar_t* output_ptr = output.mutable_data_ptr<scalar_t>();
        launch_gated_delta_prefill_kernel(
            stream.queue(),
            query_ptr,
            key_ptr,
            value_ptr,
            g_ptr,
            beta_ptr,
            state_read_ptr,
            state_write_ptr,
            output_ptr,
            batch_size,
            sequence_length,
            num_heads,
            key_head_dim,
            value_head_dim,
            local_size,
            l2_eps_f,
            query_scale_base);
      });

  return {output, final_state};
}

at::Tensor gated_delta_decode_xpu(
    const at::Tensor& query_in,
    const at::Tensor& key_in,
    const at::Tensor& value_in,
    const at::Tensor& g_in,
    const at::Tensor& beta_in,
    const at::Tensor& state_in) {
  validate_gated_delta_inputs(query_in, key_in, value_in, g_in, beta_in, state_in);
  validate_gated_delta_xpu_inputs(query_in, key_in, value_in, g_in, beta_in, state_in);
  TORCH_CHECK(query_in.size(1) == 1, "gated_delta_decode expects seq_len == 1");
  const auto initial_dtype = query_in.scalar_type();
  const auto batch_size = query_in.size(0);
  const auto num_heads = query_in.size(2);
  const auto key_head_dim = query_in.size(3);
  const auto value_head_dim = value_in.size(3);
  auto output = at::empty({batch_size, 1, num_heads, value_head_dim}, query_in.options());

  auto stream = c10::xpu::getCurrentXPUStream(query_in.device().index());
  const int64_t local_size = std::min<int64_t>(next_power_of_two(std::max<int64_t>(1, value_head_dim)), 256);
  validate_gated_delta_local_memory_requirements(stream.queue().get_device(), key_head_dim, local_size);

  const float* beta_ptr = beta_in.const_data_ptr<float>();
  const float* g_ptr = g_in.const_data_ptr<float>();
  const float* state_read_ptr = state_in.const_data_ptr<float>();
  float* state_write_ptr = state_in.mutable_data_ptr<float>();
  const float l2_eps_f = 1e-6f;
  const float query_scale_base = 1.0f / std::sqrt(static_cast<float>(key_head_dim));

  AT_DISPATCH_FLOATING_TYPES_AND2(
      at::kHalf,
      at::kBFloat16,
      initial_dtype,
      "gated_delta_decode_xpu",
      [&] {
        const scalar_t* query_ptr = query_in.const_data_ptr<scalar_t>();
        const scalar_t* key_ptr = key_in.const_data_ptr<scalar_t>();
        const scalar_t* value_ptr = value_in.const_data_ptr<scalar_t>();
        scalar_t* output_ptr = output.mutable_data_ptr<scalar_t>();
        launch_gated_delta_decode_kernel(
            stream.queue(),
            query_ptr,
            key_ptr,
            value_ptr,
            g_ptr,
            beta_ptr,
            state_read_ptr,
            state_write_ptr,
            output_ptr,
            batch_size,
            num_heads,
            key_head_dim,
            value_head_dim,
            local_size,
            l2_eps_f,
            query_scale_base);
      });

  return output;
}

} // namespace

} // namespace anna

TORCH_LIBRARY(anna, m) {
  m.def(
      "gqa_decode_fused("
      "Tensor query, "
      "Tensor key, "
      "Tensor value, "
      "Tensor visible_lengths, "
      "float scaling, "
      "Tensor? gate=None"
      ") -> Tensor");
  m.def(
      "paged_gqa_decode_fused("
      "Tensor query, "
      "Tensor key_pages, "
      "Tensor value_pages, "
      "Tensor page_table, "
      "Tensor visible_lengths, "
      "float scaling, "
      "Tensor? gate=None"
      ") -> Tensor");
  m.def(
      "moe_router_fused("
      "Tensor router_logits, "
      "int top_k, "
      "bool normalize_topk_prob=True"
      ") -> (Tensor, Tensor, Tensor)");
  m.def(
      "moe_dispatch_fused("
      "Tensor hidden_states, "
      "Tensor routing_weights, "
      "Tensor selected_experts, "
      "Tensor expert_usage"
      ") -> (Tensor, Tensor, Tensor, Tensor)");
  m.def(
      "moe_scatter_fused("
      "Tensor compact_outputs, "
      "Tensor sorted_token_idx, "
      "int num_tokens"
      ") -> Tensor");
  m.def(
      "moe_grouped_int4_mlp_fused("
      "Tensor compact_hidden_states, "
      "Tensor compact_routing_weights, "
      "Tensor(a!) compact_outputs, "
      "Tensor expert_offsets, "
      "Tensor active_experts, "
      "Tensor active_slots, "
      "Tensor gate_qweight, "
      "Tensor gate_qscale, "
      "Tensor gate_qzeros, "
      "Tensor up_qweight, "
      "Tensor up_qscale, "
      "Tensor up_qzeros, "
      "Tensor down_qweight, "
      "Tensor down_qscale, "
      "Tensor down_qzeros, "
      "int group_size, "
      "int max_routes_per_expert"
      ") -> Tensor(a!)");
  m.def(
      "rmsnorm_fused("
      "Tensor input, "
      "Tensor weight, "
      "float eps"
      ") -> Tensor");
  m.def(
      "rmsnorm_fused_ex("
      "Tensor input, "
      "Tensor weight, "
      "float eps, "
      "bool add_unit_offset=False"
      ") -> Tensor");
  m.def(
      "rmsnorm_gated_fused("
      "Tensor input, "
      "Tensor gate, "
      "Tensor weight, "
      "float eps"
      ") -> Tensor");
  m.def(
      "qk_norm_rotary_fused("
      "Tensor query, "
      "Tensor key, "
      "Tensor query_norm_weight, "
      "Tensor key_norm_weight, "
      "Tensor cos, "
      "Tensor sin, "
      "float query_norm_eps, "
      "float key_norm_eps"
      ") -> (Tensor, Tensor)");
  m.def(
      "qk_norm_rotary_fused_ex("
      "Tensor query, "
      "Tensor key, "
      "Tensor query_norm_weight, "
      "Tensor key_norm_weight, "
      "Tensor cos, "
      "Tensor sin, "
      "float query_norm_eps, "
      "float key_norm_eps, "
      "bool add_unit_offset=False"
      ") -> (Tensor, Tensor)");
  m.def(
      "causal_conv1d_prefill("
      "Tensor hidden_states, "
      "Tensor conv_state, "
      "Tensor weight, "
      "Tensor? bias=None"
      ") -> (Tensor, Tensor)");
  m.def(
      "causal_conv1d_decode("
      "Tensor hidden_states, "
      "Tensor(a!) conv_state, "
      "Tensor weight, "
      "Tensor? bias=None"
      ") -> Tensor");
  m.def(
      "gated_delta_prefill("
      "Tensor query, "
      "Tensor key, "
      "Tensor value, "
      "Tensor g, "
      "Tensor beta, "
      "Tensor state"
      ") -> (Tensor, Tensor)");
  m.def(
      "gated_delta_decode("
      "Tensor query, "
      "Tensor key, "
      "Tensor value, "
      "Tensor g, "
      "Tensor beta, "
      "Tensor(a!) state"
      ") -> Tensor");
}

